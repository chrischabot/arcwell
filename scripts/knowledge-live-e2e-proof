#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ARCWELL_BIN="${ARCWELL_BIN:-$REPO_ROOT/target/debug/arcwell}"
if [ ! -x "$ARCWELL_BIN" ]; then
  ARCWELL_BIN="$(command -v arcwell || true)"
fi

if [ -z "${ARCWELL_BIN:-}" ] || [ ! -x "$ARCWELL_BIN" ]; then
  echo "BLOCKED: arcwell binary not found. Run: cargo build -p arcwell" >&2
  exit 2
fi

for required in node curl agent-browser; do
  if ! command -v "$required" >/dev/null 2>&1; then
    echo "BLOCKED: $required is required for knowledge live E2E proof." >&2
    exit 2
  fi
done

RUN_STAMP="${ARCWELL_KNOWLEDGE_LIVE_E2E_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
PROOF_ROOT="${ARCWELL_KNOWLEDGE_LIVE_E2E_DIR:-$REPO_ROOT/.arcwell-dev/proofs/knowledge-live-e2e-proof-$RUN_STAMP}"
ARTIFACT_DIR="$PROOF_ROOT/artifacts"
export ARCWELL_HOME="${ARCWELL_KNOWLEDGE_LIVE_E2E_HOME:-$PROOF_ROOT/home}"
AUTH_TOKEN="${ARCWELL_KNOWLEDGE_LIVE_E2E_TOKEN:-knowledge-live-e2e-token-$RUN_STAMP}"
SESSION="arcwell-knowledge-live-e2e-$RUN_STAMP"

RSS_URL="${ARCWELL_KNOWLEDGE_LIVE_E2E_RSS_URL:-https://hnrss.org/newest?points=100}"
GITHUB_OWNER="${ARCWELL_KNOWLEDGE_LIVE_E2E_GITHUB_OWNER:-openai}"
ARXIV_QUERY="${ARCWELL_KNOWLEDGE_LIVE_E2E_ARXIV_QUERY:-cat:cs.AI}"
HACKERNEWS_FEED="${ARCWELL_KNOWLEDGE_LIVE_E2E_HN_FEED:-frontpage}"
PROFILE_NAME="${ARCWELL_KNOWLEDGE_LIVE_E2E_PROFILE_NAME:-knowledge-live-e2e-$RUN_STAMP}"
TOPIC="${ARCWELL_KNOWLEDGE_LIVE_E2E_TOPIC:-Live API knowledge bridge: agent infrastructure and AI developer tooling}"
MIN_ITEMS="${ARCWELL_KNOWLEDGE_LIVE_E2E_MIN_ITEMS:-12}"
MIN_SOURCE_FAMILIES="${ARCWELL_KNOWLEDGE_LIVE_E2E_MIN_FAMILIES:-3}"
MAX_SOURCE_CARDS="${ARCWELL_KNOWLEDGE_LIVE_E2E_MAX_SOURCE_CARDS:-12}"

mkdir -p "$ARTIFACT_DIR" "$ARCWELL_HOME"

log() {
  printf '[knowledge-live-e2e] %s\n' "$*"
}

cleanup() {
  if [ -n "${SERVER_PID:-}" ] && kill -0 "$SERVER_PID" >/dev/null 2>&1; then
    kill "$SERVER_PID" >/dev/null 2>&1 || true
    wait "$SERVER_PID" >/dev/null 2>&1 || true
  fi
  agent-browser --session "$SESSION" close >/dev/null 2>&1 || true
}
trap cleanup EXIT

PORT="$(node -e 'const net=require("net"); const s=net.createServer(); s.listen(0,"127.0.0.1",()=>{console.log(s.address().port); s.close();});')"
BASE_URL="http://127.0.0.1:$PORT"

log "proof root: $PROOF_ROOT"
log "ARCWELL_HOME: $ARCWELL_HOME"
log "creating live radar profile"

"$ARCWELL_BIN" radar profile create "$PROFILE_NAME" \
  --description "Live API/source adapter to unified knowledge proof over public RSS, GitHub, arXiv, and Hacker News sources." \
  --window-hours 168 \
  --min-score 1 \
  --max-items 40 \
  --selector-json "{\"kind\":\"rss\",\"locator\":\"$RSS_URL\",\"limit\":10}" \
  --selector-json "{\"kind\":\"github_owner\",\"locator\":\"$GITHUB_OWNER\",\"limit\":10}" \
  --selector-json "{\"kind\":\"arxiv\",\"locator\":\"$ARXIV_QUERY\",\"limit\":10}" \
  --selector-json "{\"kind\":\"hackernews\",\"locator\":\"$HACKERNEWS_FEED\",\"limit\":10}" \
  >"$ARTIFACT_DIR/profile.json"

log "running live radar fetch"
"$ARCWELL_BIN" radar run "$PROFILE_NAME" --window-hours 168 --fetch-live \
  >"$ARTIFACT_DIR/radar-run.json"

RADAR_RUN_ID="$(node - "$ARTIFACT_DIR/radar-run.json" "$MIN_ITEMS" <<'NODE'
const fs = require("fs");
const [path, minItemsRaw] = process.argv.slice(2);
const data = JSON.parse(fs.readFileSync(path, "utf8"));
const minItems = Number(minItemsRaw);
function fail(message, detail) {
  console.error(message);
  if (detail !== undefined) console.error(JSON.stringify(detail, null, 2));
  process.exit(1);
}
if (!data.run || !data.run.id) fail("radar output missing run id", data);
if (data.run.status !== "scored") fail("radar run did not score", data.run);
if (Number(data.items_inserted || 0) < minItems) fail("not enough live source-card items", data);
const adapterJobs = Array.isArray(data.adapter_jobs) ? data.adapter_jobs : [];
const failed = adapterJobs.filter((job) => job.status !== "completed");
if (failed.length) fail("live adapter job failed", failed);
const kinds = new Set(adapterJobs.map((job) => job.kind));
for (const expected of ["rss_fetch", "github_owner", "arxiv_search", "hackernews_fetch"]) {
  if (!kinds.has(expected)) fail(`missing adapter job ${expected}`, adapterJobs);
}
process.stdout.write(data.run.id);
NODE
)"

log "projecting radar run into unified knowledge: $RADAR_RUN_ID"
"$ARCWELL_BIN" knowledge project-radar-run "$RADAR_RUN_ID" \
  --topic "$TOPIC" \
  --max-source-cards "$MAX_SOURCE_CARDS" \
  >"$ARTIFACT_DIR/knowledge-projection.json"

"$ARCWELL_BIN" radar stage "$RADAR_RUN_ID" >"$ARTIFACT_DIR/radar-stage.json"
"$ARCWELL_BIN" knowledge entities --limit 100 >"$ARTIFACT_DIR/knowledge-entities.json"
"$ARCWELL_BIN" knowledge relations --limit 100 >"$ARTIFACT_DIR/knowledge-relations.json"
"$ARCWELL_BIN" knowledge events --limit 100 >"$ARTIFACT_DIR/knowledge-events.json"
"$ARCWELL_BIN" knowledge clusters --limit 100 >"$ARTIFACT_DIR/knowledge-clusters.json"
"$ARCWELL_BIN" knowledge reports --limit 100 >"$ARTIFACT_DIR/knowledge-reports.json"
"$ARCWELL_BIN" ops >"$ARTIFACT_DIR/ops.json"
"$ARCWELL_BIN" cursors list >"$ARTIFACT_DIR/cursors.json"

log "validating knowledge projection artifacts"
node - "$ARTIFACT_DIR" "$PROOF_ROOT" "$RADAR_RUN_ID" "$TOPIC" "$MIN_SOURCE_FAMILIES" <<'NODE'
const fs = require("fs");
const path = require("path");
const [artifactDir, proofRoot, runId, topic, minFamiliesRaw] = process.argv.slice(2);
const minFamilies = Number(minFamiliesRaw);
const read = (name) => JSON.parse(fs.readFileSync(path.join(artifactDir, name), "utf8"));
const radar = read("radar-run.json");
const projection = read("knowledge-projection.json");
const events = read("knowledge-events.json");
const clusters = read("knowledge-clusters.json");
const reports = read("knowledge-reports.json");
const ops = read("ops.json");
const cursors = read("cursors.json");
function assert(condition, message, detail) {
  if (!condition) {
    console.error(message);
    if (detail !== undefined) console.error(JSON.stringify(detail, null, 2));
    process.exit(1);
  }
}
assert(projection.proof_level === "Production Data Proof", "projection did not inherit production-data proof level", projection);
assert(projection.cluster?.topic === topic, "cluster topic mismatch", projection.cluster);
assert(Array.isArray(projection.source_cards) && projection.source_cards.length > 0, "projection has no source cards", projection);
assert(Array.isArray(projection.events) && projection.events.length > 0, "projection has no events", projection);
assert(Array.isArray(projection.entities) && projection.entities.length > 0, "projection has no entities", projection);
assert(Array.isArray(projection.relations) && projection.relations.length > 0, "projection has no relations", projection);
assert(projection.events.every((event) => event.status === "confirmed"), "not every event is confirmed", projection.events);
assert(projection.entities.every((entity) => Array.isArray(entity.source_card_ids) && entity.source_card_ids.length > 0), "not every entity is source-card backed", projection.entities);
assert(projection.relations.every((relation) => Array.isArray(relation.source_card_ids) && relation.source_card_ids.length > 0), "not every relation is source-card backed", projection.relations);
assert(projection.editorial_decision?.status === "completed", "editorial decision did not complete", projection.editorial_decision);
assert(projection.report?.body_markdown && projection.report.body_markdown.length > 500, "report body is too thin", projection.report);
assert(projection.report.body_markdown.includes("Confidence and uncertainty"), "report does not name uncertainty", projection.report.body_markdown);
for (const id of projection.cluster.source_card_ids || []) {
  assert(projection.report.body_markdown.includes(id), `report missing source-card citation ${id}`, projection.report.body_markdown);
}
const linkishLines = projection.report.body_markdown
  .split(/\n+/)
  .map((line) => line.trim())
  .filter(Boolean)
  .filter((line) => /^[-*\d. ]*https?:\/\//i.test(line));
assert(linkishLines.length < 3, "report looks like a link dump", linkishLines);
const families = new Set((projection.source_cards || []).map((card) => card.provider));
assert(families.size >= minFamilies, "not enough provider families in projection", [...families]);
assert((ops.knowledge_clusters || []).some((cluster) => cluster.id === projection.cluster.id), "ops missing knowledge cluster", ops.knowledge_clusters);
assert((ops.knowledge_reports || []).some((report) => report.id === projection.report.id), "ops missing knowledge report", ops.knowledge_reports);
for (const entity of projection.entities) {
  assert((ops.knowledge_entities || []).some((opsEntity) => opsEntity.id === entity.id), `ops missing knowledge entity ${entity.id}`, ops.knowledge_entities);
}
for (const relation of projection.relations) {
  assert((ops.knowledge_relations || []).some((opsRelation) => opsRelation.id === relation.id), `ops missing knowledge relation ${relation.id}`, ops.knowledge_relations);
}
const cursorKeys = new Set((cursors || []).map((cursor) => cursor.key));
assert([...cursorKeys].some((key) => key.startsWith("github-owner:")), "missing GitHub cursor", cursors);
assert([...cursorKeys].some((key) => key.startsWith("hackernews:")), "missing Hacker News cursor", cursors);
const proof = {
  proof_name: "knowledge-live-e2e-proof",
  proof_level: "Production Data Proof for live public adapter fetch -> source cards -> unified knowledge projection -> browser-visible ops UI",
  proof_root: proofRoot,
  arcwell_home: process.env.ARCWELL_HOME,
  radar_run_id: runId,
  topic,
  source_card_count: projection.source_cards.length,
  event_count: projection.events.length,
  entity_count: projection.entities.length,
  relation_count: projection.relations.length,
  provider_families: [...families].sort(),
  cluster_id: projection.cluster.id,
  editorial_decision_id: projection.editorial_decision.id,
  report_id: projection.report.id,
  artifacts: {
    profile: path.join(artifactDir, "profile.json"),
    radar_run: path.join(artifactDir, "radar-run.json"),
    radar_stage: path.join(artifactDir, "radar-stage.json"),
    knowledge_projection: path.join(artifactDir, "knowledge-projection.json"),
    knowledge_entities: path.join(artifactDir, "knowledge-entities.json"),
    knowledge_relations: path.join(artifactDir, "knowledge-relations.json"),
    ops: path.join(artifactDir, "ops.json"),
    cursors: path.join(artifactDir, "cursors.json")
  },
  checked: [
    "live public adapters completed for RSS, GitHub owner, arXiv, and Hacker News",
    "radar run reached scored status and wrote selected source-card evidence",
    "unified knowledge projection created confirmed events plus source-backed entities and relations",
    "cluster/editorial/report rows are durable and ops-visible",
    "report body is human-readable and cites all cluster source-card IDs",
    "provider cursors are visible after durable writes"
  ],
  remaining_risk: [
    "This proves a foreground live E2E run, not scheduled recurrence.",
    "This uses public live sources; X live breadth still depends on refreshed X credentials.",
    "The report writer is deterministic source-card prose, not model-backed semantic synthesis."
  ]
};
fs.writeFileSync(path.join(artifactDir, "proof-packet.pre-browser.json"), JSON.stringify(proof, null, 2));
NODE

log "starting authenticated local HTTP server on $BASE_URL"
"$ARCWELL_BIN" serve --addr "127.0.0.1:$PORT" --auth-token "$AUTH_TOKEN" \
  >"$ARTIFACT_DIR/server.log" 2>&1 &
SERVER_PID="$!"

for _ in $(seq 1 100); do
  if curl -fsS -H "x-arcwell-http-token: $AUTH_TOKEN" "$BASE_URL/health" >/dev/null 2>&1; then
    break
  fi
  if ! kill -0 "$SERVER_PID" >/dev/null 2>&1; then
    echo "BLOCKED: HTTP server exited before readiness. See $ARTIFACT_DIR/server.log" >&2
    exit 2
  fi
  sleep 0.1
done

if ! curl -fsS -H "x-arcwell-http-token: $AUTH_TOKEN" "$BASE_URL/health" >/dev/null 2>&1; then
  echo "BLOCKED: HTTP server did not become ready. See $ARTIFACT_DIR/server.log" >&2
  exit 2
fi

agent-browser --session "$SESSION" set headers "{\"x-arcwell-http-token\":\"$AUTH_TOKEN\"}" >/dev/null

log "checking desktop ops UI"
agent-browser --session "$SESSION" set viewport 1440 900 >/dev/null
agent-browser --session "$SESSION" open "$BASE_URL/ops/ui" >/dev/null
agent-browser --session "$SESSION" wait --load networkidle >/dev/null
agent-browser --session "$SESSION" screenshot "$ARTIFACT_DIR/desktop.png" >/dev/null
agent-browser --session "$SESSION" snapshot -i >"$ARTIFACT_DIR/desktop.snapshot.txt"
agent-browser --session "$SESSION" eval "$(cat <<'JS'
(() => {
  const text = document.body.innerText;
  for (const needle of ["Arcwell Ops", "Knowledge Entities", "Knowledge Relations", "Knowledge Events", "Knowledge Clusters", "Knowledge Reports", "Live API knowledge bridge"]) {
    if (!text.includes(needle)) throw new Error(`missing desktop text: ${needle}`);
  }
  if (document.scripts.length !== 0) throw new Error(`unexpected script tags: ${document.scripts.length}`);
  if (document.documentElement.scrollWidth > window.innerWidth + 4) {
    throw new Error(`desktop horizontal overflow: ${document.documentElement.scrollWidth} > ${window.innerWidth}`);
  }
  return {
    title: document.title,
    width: window.innerWidth,
    sections: document.querySelectorAll("section").length,
    metrics: document.querySelectorAll(".metric").length
  };
})()
JS
)" >"$ARTIFACT_DIR/desktop.assertion.json"

log "checking mobile ops UI"
agent-browser --session "$SESSION" set viewport 390 844 >/dev/null
agent-browser --session "$SESSION" open "$BASE_URL/ops/ui" >/dev/null
agent-browser --session "$SESSION" wait --load networkidle >/dev/null
agent-browser --session "$SESSION" screenshot "$ARTIFACT_DIR/mobile.png" >/dev/null
agent-browser --session "$SESSION" snapshot -i >"$ARTIFACT_DIR/mobile.snapshot.txt"
agent-browser --session "$SESSION" eval "$(cat <<'JS'
(() => {
  const text = document.body.innerText;
  for (const needle of ["Arcwell Ops", "Knowledge Entities", "Knowledge Relations", "Knowledge Clusters", "Knowledge Reports"]) {
    if (!text.includes(needle)) throw new Error(`missing mobile text: ${needle}`);
  }
  if (!document.querySelector("form.ops-form")) throw new Error("missing mobile filter form");
  if (document.scripts.length !== 0) throw new Error(`unexpected mobile script tags: ${document.scripts.length}`);
  if (document.documentElement.scrollWidth > window.innerWidth + 4) {
    throw new Error(`mobile horizontal overflow: ${document.documentElement.scrollWidth} > ${window.innerWidth}`);
  }
  return {
    title: document.title,
    width: window.innerWidth,
    sections: document.querySelectorAll("section").length,
    metrics: document.querySelectorAll(".metric").length
  };
})()
JS
)" >"$ARTIFACT_DIR/mobile.assertion.json"

agent-browser --session "$SESSION" errors >"$ARTIFACT_DIR/browser-errors.txt" || true

node - "$ARTIFACT_DIR" "$BASE_URL" <<'NODE' >"$ARTIFACT_DIR/proof-packet.json"
const fs = require("fs");
const path = require("path");
const [artifactDir, baseUrl] = process.argv.slice(2);
const proof = JSON.parse(fs.readFileSync(path.join(artifactDir, "proof-packet.pre-browser.json"), "utf8"));
proof.base_url = baseUrl;
proof.artifacts.desktop_screenshot = path.join(artifactDir, "desktop.png");
proof.artifacts.mobile_screenshot = path.join(artifactDir, "mobile.png");
proof.artifacts.desktop_snapshot = path.join(artifactDir, "desktop.snapshot.txt");
proof.artifacts.mobile_snapshot = path.join(artifactDir, "mobile.snapshot.txt");
proof.artifacts.browser_errors = path.join(artifactDir, "browser-errors.txt");
proof.desktop = JSON.parse(fs.readFileSync(path.join(artifactDir, "desktop.assertion.json"), "utf8"));
proof.mobile = JSON.parse(fs.readFileSync(path.join(artifactDir, "mobile.assertion.json"), "utf8"));
proof.checked.push("authenticated /ops/ui desktop and mobile browser render includes knowledge tables without horizontal overflow");
process.stdout.write(JSON.stringify(proof, null, 2));
NODE

cat "$ARTIFACT_DIR/proof-packet.json"
log "knowledge live E2E proof passed"
log "proof packet: $ARTIFACT_DIR/proof-packet.json"
