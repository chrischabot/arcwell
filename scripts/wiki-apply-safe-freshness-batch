#!/usr/bin/env python3
"""Apply gated Arcwell wiki freshness candidates to existing page files.

This script is intentionally conservative:
- it only accepts rows already marked safe_batch_candidate by wiki-freshness-scan
- it writes source-card ids into page content so later scans can suppress repeats
- it backs up every changed page before writing
- it refreshes wiki_pages metadata and FTS rows for changed pages
"""

from __future__ import annotations

import argparse
import csv
import hashlib
import json
import os
import shutil
import sqlite3
from dataclasses import dataclass
from datetime import UTC, datetime
from pathlib import Path


SECTION_HEADING = "## Recent Source-Backed Updates"


def default_db_path() -> Path:
    return Path(os.environ.get("ARCWELL_HOME", Path.home() / ".arcwell")) / "arcwell.sqlite3"


def now_iso() -> str:
    return datetime.now(UTC).isoformat()


def date_part(value: str) -> str:
    if not value:
        return "unknown date"
    return value.split("T", 1)[0]


def split_semicolon(value: str) -> list[str]:
    return [part.strip() for part in (value or "").split(";") if part.strip()]


@dataclass
class Candidate:
    rank: str
    score: float
    review_gate: str
    page_id: str
    page_title: str
    page_path: Path
    newest_evidence_at: str
    primary_count: int
    secondary_count: int
    signal_count: int
    source_card_ids: list[str]


def load_candidates(
    path: Path,
    limit: int,
    min_score: float,
    allow_editorial_decision_updates: bool,
) -> list[Candidate]:
    candidates: list[Candidate] = []
    with path.open(newline="", encoding="utf-8") as handle:
        reader = csv.DictReader(handle)
        for row in reader:
            review_gate = row.get("review_gate") or ""
            allowed_review_gates = {"safe_batch_candidate"}
            if allow_editorial_decision_updates:
                allowed_review_gates.add("editorial_decision_update_existing")
            if review_gate not in allowed_review_gates:
                continue
            if row.get("action") != "update_existing_page":
                continue
            score = float(row.get("score") or 0)
            if score < min_score:
                continue
            candidates.append(
                Candidate(
                    rank=row.get("rank") or "",
                    score=score,
                    review_gate=review_gate,
                    page_id=row.get("page_id") or "",
                    page_title=row.get("page_title") or "",
                    page_path=Path(row.get("page_path") or ""),
                    newest_evidence_at=row.get("newest_evidence_at") or "",
                    primary_count=int(row.get("primary_count") or 0),
                    secondary_count=int(row.get("secondary_count") or 0),
                    signal_count=int(row.get("signal_count") or 0),
                    source_card_ids=split_semicolon(row.get("source_card_ids") or ""),
                )
            )
            if limit and len(candidates) >= limit:
                break
    return candidates


def fetch_source_cards(conn: sqlite3.Connection, ids: list[str], max_cards: int) -> list[sqlite3.Row]:
    wanted = ids[:max_cards]
    if not wanted:
        return []
    placeholders = ",".join("?" for _ in wanted)
    rows = conn.execute(
        f"""
        SELECT id, title, url, source_type, provider, summary, retrieved_at
        FROM source_cards
        WHERE id IN ({placeholders})
        """,
        wanted,
    ).fetchall()
    by_id = {row["id"]: row for row in rows}
    return [by_id[source_id] for source_id in wanted if source_id in by_id]


def ensure_page_is_known(
    conn: sqlite3.Connection, candidate: Candidate, db_path: Path
) -> sqlite3.Row:
    row = conn.execute(
        """
        SELECT id, title, path
        FROM wiki_pages
        WHERE id = ?1
          AND status = 'active'
        """,
        (candidate.page_id,),
    ).fetchone()
    if row is None:
        raise RuntimeError(f"no active wiki page row for {candidate.page_id}")
    resolved_row_path = Path(row["path"]).expanduser().resolve()
    resolved_candidate_path = candidate.page_path.expanduser().resolve()
    if resolved_row_path != resolved_candidate_path:
        raise RuntimeError(
            f"candidate path mismatch for {candidate.page_id}: "
            f"{resolved_candidate_path} != {resolved_row_path}"
        )
    wiki_pages_dir = (db_path.expanduser().resolve().parent / "wiki" / "pages").resolve()
    if wiki_pages_dir not in resolved_candidate_path.parents:
        raise RuntimeError(f"refusing to edit page outside wiki pages dir: {resolved_candidate_path}")
    if not resolved_candidate_path.exists():
        raise RuntimeError(f"page file missing: {resolved_candidate_path}")
    return row


def markdown_link(title: str, url: str) -> str:
    safe_title = (title or url or "source").replace("[", "\\[").replace("]", "\\]")
    if not url:
        return safe_title
    safe_url = url.replace(")", "%29")
    return f"[{safe_title}]({safe_url})"


def build_bullet(candidate: Candidate, cards: list[sqlite3.Row], timestamp: str) -> str:
    evidence_parts = []
    for row in cards:
        evidence_parts.append(
            f"{markdown_link(row['title'], row['url'])} "
            f"(source card `{row['id']}`, retrieved {date_part(row['retrieved_at'])})"
        )
    evidence = "; ".join(evidence_parts)
    if not evidence:
        evidence = "the matched source cards listed by the freshness scan"
    mix = (
        f"{candidate.primary_count} primary, "
        f"{candidate.secondary_count} secondary, "
        f"{candidate.signal_count} signal"
    )
    return (
        f"- {date_part(timestamp)} freshness scan: recent source-card evidence for "
        f"{candidate.page_title} includes {evidence}. Evidence mix: {mix}. "
        "This records current source-backed activity, not a complete replacement "
        "for the page's older background material."
    )


def insert_bullet(content: str, bullet: str) -> str:
    if SECTION_HEADING in content:
        lines = content.splitlines()
        for index, line in enumerate(lines):
            if line.strip() == SECTION_HEADING:
                insert_at = index + 1
                while insert_at < len(lines) and lines[insert_at].strip() == "":
                    insert_at += 1
                lines.insert(insert_at, bullet)
                if insert_at == index + 1:
                    lines.insert(insert_at + 1, "")
                return "\n".join(lines).rstrip() + "\n"

    markers = ["\n## See Also", "\n## References", "\n#AI"]
    insert_at = len(content)
    for marker in markers:
        marker_index = content.find(marker)
        if marker_index != -1:
            insert_at = marker_index
            break
    prefix = content[:insert_at].rstrip()
    suffix = content[insert_at:].lstrip("\n")
    section = f"\n\n{SECTION_HEADING}\n\n{bullet}\n"
    if suffix:
        return prefix + section + "\n" + suffix
    return prefix + section


def refresh_index(conn: sqlite3.Connection, page_id: str, title: str, path: Path, timestamp: str) -> str:
    content = path.read_text(encoding="utf-8")
    digest = hashlib.sha256(content.encode("utf-8")).hexdigest()
    conn.execute(
        """
        UPDATE wiki_pages
        SET content_sha256 = ?2,
            updated_at = ?3
        WHERE id = ?1
        """,
        (page_id, digest, timestamp),
    )
    conn.execute("DELETE FROM wiki_pages_fts WHERE id = ?1", (page_id,))
    conn.execute(
        "INSERT INTO wiki_pages_fts (id, title, content) VALUES (?1, ?2, ?3)",
        (page_id, title, content),
    )
    return digest


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Apply safe_batch_candidate wiki freshness rows to page files."
    )
    parser.add_argument("--candidates", required=True, type=Path)
    parser.add_argument("--db", type=Path, default=default_db_path())
    parser.add_argument("--proof-dir", required=True, type=Path)
    parser.add_argument("--limit", type=int, default=0)
    parser.add_argument("--min-score", type=float, default=100.0)
    parser.add_argument("--max-source-cards", type=int, default=5)
    parser.add_argument(
        "--allow-editorial-decision-updates",
        action="store_true",
        help=(
            "Also accept rows exported by wiki-validate-editorial-decisions "
            "with review_gate=editorial_decision_update_existing."
        ),
    )
    mode = parser.add_mutually_exclusive_group(required=True)
    mode.add_argument("--dry-run", action="store_true")
    mode.add_argument("--apply", action="store_true")
    args = parser.parse_args()

    args.proof_dir.mkdir(parents=True, exist_ok=True)
    backup_dir = args.proof_dir / "backups"
    if args.apply:
        backup_dir.mkdir(parents=True, exist_ok=True)
    timestamp = now_iso()
    candidates = load_candidates(
        args.candidates,
        args.limit,
        args.min_score,
        args.allow_editorial_decision_updates,
    )
    results = []

    with sqlite3.connect(args.db) as conn:
        conn.row_factory = sqlite3.Row
        for candidate in candidates:
            result = {
                "page_id": candidate.page_id,
                "page_title": candidate.page_title,
                "page_path": str(candidate.page_path),
                "score": candidate.score,
                "status": "planned",
                "source_card_ids": candidate.source_card_ids,
            }
            try:
                row = ensure_page_is_known(conn, candidate, args.db)
                page_path = candidate.page_path.expanduser().resolve()
                content = page_path.read_text(encoding="utf-8")
                already_cited_ids = [
                    source_id for source_id in candidate.source_card_ids if source_id in content
                ]
                if already_cited_ids:
                    result["status"] = "skipped_already_cited"
                    result["already_cited_source_card_ids"] = already_cited_ids
                    results.append(result)
                    continue
                cards = fetch_source_cards(conn, candidate.source_card_ids, args.max_source_cards)
                bullet = build_bullet(candidate, cards, timestamp)
                result["bullet"] = bullet
                result["applied_source_card_ids"] = [row["id"] for row in cards]
                if not cards:
                    result["status"] = "skipped_missing_source_cards"
                    results.append(result)
                    continue
                if args.dry_run:
                    result["status"] = "dry_run"
                    results.append(result)
                    continue
                backup_path = backup_dir / f"{candidate.page_id}.md"
                shutil.copy2(page_path, backup_path)
                updated = insert_bullet(content, bullet)
                page_path.write_text(updated, encoding="utf-8")
                digest = refresh_index(conn, candidate.page_id, row["title"], page_path, timestamp)
                result["status"] = "applied"
                result["backup_path"] = str(backup_path)
                result["content_sha256"] = digest
            except Exception as exc:
                result["status"] = "error"
                result["error"] = str(exc)
            results.append(result)

    summary = {
        "ok": all(result["status"] != "error" for result in results),
        "mode": "apply" if args.apply else "dry_run",
        "generated_at": timestamp,
        "db": str(args.db),
        "candidates": str(args.candidates),
        "proof_dir": str(args.proof_dir),
        "allow_editorial_decision_updates": args.allow_editorial_decision_updates,
        "candidate_count": len(results),
        "applied": sum(1 for result in results if result["status"] == "applied"),
        "dry_run": sum(1 for result in results if result["status"] == "dry_run"),
        "skipped_already_cited": sum(
            1 for result in results if result["status"] == "skipped_already_cited"
        ),
        "skipped_missing_source_cards": sum(
            1 for result in results if result["status"] == "skipped_missing_source_cards"
        ),
        "errors": [result for result in results if result["status"] == "error"],
    }
    (args.proof_dir / "wiki_safe_batch_apply_summary.json").write_text(
        json.dumps(summary, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )
    with (args.proof_dir / "wiki_safe_batch_apply_results.jsonl").open(
        "w", encoding="utf-8"
    ) as handle:
        for result in results:
            handle.write(json.dumps(result, sort_keys=True) + "\n")
    with (args.proof_dir / "wiki_safe_batch_apply_results.csv").open(
        "w", newline="", encoding="utf-8"
    ) as handle:
        fieldnames = [
            "page_id",
            "page_title",
            "page_path",
            "score",
            "status",
            "applied_source_card_ids",
            "backup_path",
            "error",
        ]
        writer = csv.DictWriter(handle, fieldnames=fieldnames)
        writer.writeheader()
        for result in results:
            writer.writerow(
                {
                    "page_id": result.get("page_id", ""),
                    "page_title": result.get("page_title", ""),
                    "page_path": result.get("page_path", ""),
                    "score": result.get("score", ""),
                    "status": result.get("status", ""),
                    "applied_source_card_ids": ";".join(
                        result.get("applied_source_card_ids", [])
                    ),
                    "backup_path": result.get("backup_path", ""),
                    "error": result.get("error", ""),
                }
            )
    print(json.dumps(summary, indent=2, sort_keys=True))
    return 0 if summary["ok"] else 1


if __name__ == "__main__":
    raise SystemExit(main())
