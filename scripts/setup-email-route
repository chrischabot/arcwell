#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
WORKER_DIR="$REPO_ROOT/packages/arcwell-edge-inbox/worker"

if [ "${ARCWELL_EMAIL_SETUP_CONFIRM:-}" != "configure" ]; then
  echo "BLOCKED: refusing to modify Cloudflare email state without ARCWELL_EMAIL_SETUP_CONFIRM=configure." >&2
  echo "This script can set Worker secrets, deploy the Arcwell edge inbox Worker, and create/update one Email Routing rule." >&2
  exit 2
fi

if ! command -v node >/dev/null 2>&1; then
  echo "BLOCKED: node is required." >&2
  exit 2
fi

if [ -z "${ARCWELL_EMAIL_ROUTE_RECIPIENT:-}" ]; then
  echo "BLOCKED: ARCWELL_EMAIL_ROUTE_RECIPIENT is required, for example agent@example.com." >&2
  exit 2
fi

if [ -z "${ARCWELL_AUTHOR_EMAILS:-${ARCWELL_AUTHOR_EMAIL:-}}" ]; then
  echo "BLOCKED: ARCWELL_AUTHOR_EMAILS or ARCWELL_AUTHOR_EMAIL is required, for example user@example.com." >&2
  exit 2
fi

WORKER_NAME="${ARCWELL_EMAIL_WORKER_NAME:-arcwell-edge-inbox}"
ROUTE_NAME="${ARCWELL_EMAIL_ROUTE_NAME:-Arcwell agent email}"
AUTHOR_EMAILS="${ARCWELL_AUTHOR_EMAILS:-$ARCWELL_AUTHOR_EMAIL}"
RECIPIENT="$ARCWELL_EMAIL_ROUTE_RECIPIENT"
export AUTHOR_EMAILS RECIPIENT WORKER_NAME ROUTE_NAME

route_json="$(node - <<'NODE'
function normalize(value) {
  const email = String(value || "").trim().toLowerCase();
  if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) throw new Error(`invalid email address: ${value}`);
  return email;
}
const recipient = normalize(process.env.RECIPIENT);
const authors = String(process.env.AUTHOR_EMAILS || "")
  .split(",")
  .map(normalize)
  .filter(Boolean);
if (authors.length === 0) throw new Error("no author emails configured");
process.stdout.write(JSON.stringify([{ id: "arcwell-agent", recipient, allowedSenders: authors }]));
NODE
)"

echo "Setting EMAIL_ROUTES_JSON Worker secret for $WORKER_NAME."
printf '%s' "$route_json" | (cd "$WORKER_DIR" && npx wrangler secret put EMAIL_ROUTES_JSON)

if [ "${ARCWELL_EMAIL_DEPLOY:-1}" = "1" ]; then
  echo "Deploying $WORKER_NAME with current email handler."
  (cd "$WORKER_DIR" && npx wrangler deploy)
else
  echo "Skipping Worker deploy because ARCWELL_EMAIL_DEPLOY=$ARCWELL_EMAIL_DEPLOY."
fi

if [ -z "${CLOUDFLARE_API_TOKEN:-}" ]; then
  echo "BLOCKED: CLOUDFLARE_API_TOKEN is required to create/update the Email Routing rule." >&2
  exit 2
fi

DOMAIN="${ARCWELL_EMAIL_ROUTE_DOMAIN:-${RECIPIENT#*@}}"
export DOMAIN

node - <<'NODE'
const token = process.env.CLOUDFLARE_API_TOKEN;
const domain = process.env.DOMAIN;
const recipient = process.env.RECIPIENT.toLowerCase();
const worker = process.env.WORKER_NAME;
const routeName = process.env.ROUTE_NAME;

async function cf(path, init = {}) {
  const response = await fetch(`https://api.cloudflare.com/client/v4${path}`, {
    ...init,
    headers: {
      authorization: `Bearer ${token}`,
      "content-type": "application/json",
      ...(init.headers || {}),
    },
  });
  const body = await response.json().catch(() => ({}));
  if (!response.ok || body.success === false) {
    const errors = (body.errors || []).map((error) => `${error.code || "unknown"} ${error.message || ""}`).join("; ");
    const err = new Error(errors || `Cloudflare API HTTP ${response.status}`);
    err.status = response.status;
    throw err;
  }
  return body.result;
}

(async () => {
  const zones = await cf(`/zones?name=${encodeURIComponent(domain)}`);
  const zone = zones?.[0];
  if (!zone) throw new Error(`zone not found for ${domain}`);
  const rules = await cf(`/zones/${zone.id}/email/routing/rules`);
  const existing = (rules || []).find((rule) =>
    (rule.matchers || []).some((matcher) => matcher.field === "to" && String(matcher.value || "").toLowerCase() === recipient)
  );
  const payload = {
    enabled: true,
    name: routeName,
    matchers: [{ type: "literal", field: "to", value: recipient }],
    actions: [{ type: "worker", value: [worker] }],
    priority: 0,
  };
  const result = existing
    ? await cf(`/zones/${zone.id}/email/routing/rules/${existing.id}`, { method: "PUT", body: JSON.stringify(payload) })
    : await cf(`/zones/${zone.id}/email/routing/rules`, { method: "POST", body: JSON.stringify(payload) });
  console.log(JSON.stringify({
    ok: true,
    domain,
    worker,
    route_id: result.id,
    route_name: result.name,
    enabled: result.enabled,
  }, null, 2));
})().catch((error) => {
  console.error(`BLOCKED: Cloudflare Email Routing rule update failed: ${error.message}`);
  process.exit(2);
});
NODE
