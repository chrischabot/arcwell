#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ARCWELL_BIN="${ARCWELL_BIN:-$REPO_ROOT/target/debug/arcwell}"
if [ ! -x "$ARCWELL_BIN" ]; then
  ARCWELL_BIN="$(command -v arcwell || true)"
fi

if [ -z "${ARCWELL_BIN:-}" ] || [ ! -x "$ARCWELL_BIN" ]; then
  echo "BLOCKED: arcwell binary not found. Run: cargo build -p arcwell" >&2
  exit 2
fi

for required in node sqlite3; do
  if ! command -v "$required" >/dev/null 2>&1; then
    echo "BLOCKED: $required is required for this proof." >&2
    exit 2
  fi
done

RUN_STAMP="${ARCWELL_CREDENTIAL_REMINDER_PROOF_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
PROOF_ROOT="${ARCWELL_CREDENTIAL_REMINDER_PROOF_DIR:-$REPO_ROOT/.arcwell-dev/proofs/credential-reminder-scheduled-proof-$RUN_STAMP}"
ARTIFACT_DIR="$PROOF_ROOT/artifacts"
export ARCWELL_HOME="${ARCWELL_CREDENTIAL_REMINDER_PROOF_HOME:-$PROOF_ROOT/home}"
RECIPIENT="${ARCWELL_CREDENTIAL_REMINDER_EMAIL_TO:-credential-reminder-proof@example.com}"
FROM="${ARCWELL_CREDENTIAL_REMINDER_EMAIL_FROM:-agent@example.com}"
SENTINEL_TOKEN="credential-proof-token-SHOULD_NOT_LEAK-${RUN_STAMP}"

mkdir -p "$ARTIFACT_DIR" "$ARCWELL_HOME"

log() {
  printf '[credential-reminder-proof] %s\n' "$*"
}

fail() {
  printf '[credential-reminder-proof] BLOCKED: %s\n' "$*" >&2
  exit 2
}

MOCK_BASE_FILE="$ARTIFACT_DIR/email-api-base.txt"
MOCK_LOG_FILE="$ARTIFACT_DIR/email-provider-requests.jsonl"
node - "$MOCK_BASE_FILE" "$MOCK_LOG_FILE" <<'NODE' &
const fs = require("fs");
const http = require("http");
const [basePath, logPath] = process.argv.slice(2);

const server = http.createServer((req, res) => {
  const chunks = [];
  req.on("data", (chunk) => chunks.push(chunk));
  req.on("end", () => {
    const body = Buffer.concat(chunks).toString("utf8");
    fs.appendFileSync(
      logPath,
      `${JSON.stringify({
        method: req.method,
        url: req.url,
        content_type: req.headers["content-type"] || null,
        authorization: req.headers.authorization ? "<redacted>" : null,
        body,
      })}\n`
    );
    res.writeHead(200, { "content-type": "application/json" });
    res.end(JSON.stringify({ success: true, result: { id: "credential_reminder_email_ok" } }));
  });
});

server.listen(0, "127.0.0.1", () => {
  const address = server.address();
  fs.writeFileSync(basePath, `http://127.0.0.1:${address.port}\n`);
});

process.on("SIGTERM", () => server.close(() => process.exit(0)));
NODE
MOCK_PID=$!
trap 'kill "$MOCK_PID" >/dev/null 2>&1 || true' EXIT

for _ in $(seq 1 50); do
  [ -s "$MOCK_BASE_FILE" ] && break
  sleep 0.1
done
[ -s "$MOCK_BASE_FILE" ] || fail "controlled Cloudflare Email endpoint did not start"
EMAIL_API_BASE="$(tr -d '\n' <"$MOCK_BASE_FILE")"
EXPIRES_AT="$(node -e 'process.stdout.write(new Date(Date.now() + 8 * 60 * 60 * 1000).toISOString())')"

log "proof root: $PROOF_ROOT"
cat >"$ARCWELL_HOME/arcwell-policy.toml" <<POLICY
[[rules]]
id = "allow-credential-reminder-secret-x-bearer"
effect = "allow"
action = "secret.write"
provider = "x"
target = "X_BEARER_TOKEN"
reason = "allow proof X bearer sentinel"
priority = 30

[[rules]]
id = "allow-credential-reminder-secret-email-account"
effect = "allow"
action = "secret.write"
provider = "email"
target = "CLOUDFLARE_ACCOUNT_ID"
reason = "allow controlled email account"
priority = 30

[[rules]]
id = "allow-credential-reminder-secret-email-token"
effect = "allow"
action = "secret.write"
provider = "email"
target = "CLOUDFLARE_EMAIL_API_TOKEN"
reason = "allow controlled email token"
priority = 30

[[rules]]
id = "allow-credential-reminder-secret-email-from"
effect = "allow"
action = "secret.write"
provider = "email"
target = "ARCWELL_AGENT_EMAIL_FROM"
reason = "allow controlled email sender"
priority = 30

[[rules]]
id = "allow-credential-reminder-secret-email-base"
effect = "allow"
action = "secret.write"
provider = "email"
target = "CLOUDFLARE_EMAIL_API_BASE"
reason = "allow controlled email API base"
priority = 30

[[rules]]
id = "allow-credential-reminder-worker-enqueue"
effect = "allow"
action = "worker.enqueue"
reason = "allow scheduled credential reminder worker enqueue"
priority = 20

[[rules]]
id = "allow-credential-reminder-source-card"
effect = "allow"
action = "source.write"
package = "arcwell-llm-wiki"
provider = "arcwell"
source = "source_card_add"
reason = "allow internal credential health source-card snapshot"
priority = 20

[[rules]]
id = "allow-credential-reminder-auto-approve"
effect = "allow"
action = "credential_reminder.auto_approve"
package = "arcwell-ops"
provider = "arcwell"
source = "secret_health"
channel = "email"
subject = "email:$RECIPIENT"
target = "email:$RECIPIENT"
reason = "allow controlled scheduled credential reminder"
priority = 20

[[rules]]
id = "allow-credential-reminder-digest-delivery"
effect = "allow"
action = "digest_candidate.deliver"
package = "arcwell-ops"
source = "credential_reminder_delivery"
channel = "email"
subject = "email:$RECIPIENT"
target = "email:$RECIPIENT"
reason = "allow reviewed credential reminder email delivery"
priority = 10

[[rules]]
id = "allow-credential-reminder-channel-send"
effect = "allow"
action = "channel.send"
package = "arcwell-email"
provider = "cloudflare_email"
source = "email_send"
channel = "email"
subject = "email:$RECIPIENT"
target = "$RECIPIENT"
reason = "allow controlled credential reminder email send"
priority = 10
POLICY

log "seeding expiring X credential and controlled email provider config"
"$ARCWELL_BIN" secrets set-value X_BEARER_TOKEN "$SENTINEL_TOKEN" --scope x --provider x --expires-at "$EXPIRES_AT" >"$ARTIFACT_DIR/x-bearer-set.json"
"$ARCWELL_BIN" secrets set-value CLOUDFLARE_ACCOUNT_ID credentialreminderacct --scope email --provider email >"$ARTIFACT_DIR/email-account-set.json"
"$ARCWELL_BIN" secrets set-value CLOUDFLARE_EMAIL_API_TOKEN credential-reminder-token --scope email --provider email >"$ARTIFACT_DIR/email-token-set.json"
"$ARCWELL_BIN" secrets set-value ARCWELL_AGENT_EMAIL_FROM "$FROM" --scope email --provider email >"$ARTIFACT_DIR/email-from-set.json"
"$ARCWELL_BIN" secrets set-value CLOUDFLARE_EMAIL_API_BASE "$EMAIL_API_BASE" --scope email --provider email >"$ARTIFACT_DIR/email-base-set.json"
"$ARCWELL_BIN" x schedule-bookmarks --bookmark-days 92 --max-bookmarks 100 --cadence warm --status active >"$ARTIFACT_DIR/x-bookmarks-schedule.json"
NEXT_BOOKMARK_RUN_AT="$(node -e 'process.stdout.write(new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString())')"
sqlite3 "$ARCWELL_HOME/arcwell.sqlite3" <<SQL
INSERT INTO source_health
  (key, provider, source_kind, locator, status, last_success_at, last_failure_at,
   last_error, last_item_id, last_item_date, cursor_key, cursor_value, next_run_at, updated_at)
VALUES
  ('x:bookmarks', 'x', 'x_import_bookmarks', 'bookmarks', 'healthy', NULL, NULL,
   NULL, NULL, NULL, 'x:bookmarks', NULL, '$NEXT_BOOKMARK_RUN_AT', '$NEXT_BOOKMARK_RUN_AT')
ON CONFLICT(key) DO UPDATE SET
  provider = excluded.provider,
  source_kind = excluded.source_kind,
  locator = excluded.locator,
  status = excluded.status,
  next_run_at = excluded.next_run_at,
  updated_at = excluded.updated_at;
SQL
"$ARCWELL_BIN" email authorize "$RECIPIENT" --send >"$ARTIFACT_DIR/email-authorization.json"
"$ARCWELL_BIN" secrets health >"$ARTIFACT_DIR/secret-health-before.json"

log "creating scheduled credential reminder route"
"$ARCWELL_BIN" digest-alert-schedule-create --json "{\"name\":\"credential reminders\",\"channel\":\"email\",\"recipient_ref\":\"email:$RECIPIENT\",\"min_score\":0,\"max_candidates\":1,\"interval_hours\":24}" >"$ARTIFACT_DIR/schedule.json"
SCHEDULE_ID="$(node -e 'const fs=require("fs"); const j=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); process.stdout.write(j.id)' "$ARTIFACT_DIR/schedule.json")"

log "draining resident worker once for scheduled reminder delivery"
"$ARCWELL_BIN" worker run-once --max-jobs 3 >"$ARTIFACT_DIR/worker-first.json"
"$ARCWELL_BIN" digest-alert-ticks --json "{\"schedule_id\":\"$SCHEDULE_ID\"}" >"$ARTIFACT_DIR/ticks-after-first.json"
"$ARCWELL_BIN" digest-candidates >"$ARTIFACT_DIR/candidates-after-first.json"
"$ARCWELL_BIN" digest-candidate-deliveries >"$ARTIFACT_DIR/deliveries-after-first.json"
"$ARCWELL_BIN" source-card search "credential health snapshot" >"$ARTIFACT_DIR/source-cards-after-first.json"

log "draining resident worker again to prove duplicate suppression"
"$ARCWELL_BIN" worker run-once --max-jobs 3 >"$ARTIFACT_DIR/worker-second.json"
"$ARCWELL_BIN" digest-alert-ticks --json "{\"schedule_id\":\"$SCHEDULE_ID\"}" >"$ARTIFACT_DIR/ticks-after-second.json"

NOW_MINUTES="$(date -u '+%H %M' | awk '{ print ($1 * 60) + $2 }')"
START_MINUTES=$(( (NOW_MINUTES + 24 * 60 - 5) % (24 * 60) ))
END_MINUTES=$(( (NOW_MINUTES + 5) % (24 * 60) ))
START_HHMM="$(printf '%02d:%02d' $((START_MINUTES / 60)) $((START_MINUTES % 60)))"
END_HHMM="$(printf '%02d:%02d' $((END_MINUTES / 60)) $((END_MINUTES % 60)))"

log "creating quiet-hours credential reminder route; it should defer before materialization"
"$ARCWELL_BIN" digest-alert-schedule-create --json "{\"name\":\"credential reminders quiet $RUN_STAMP\",\"channel\":\"email\",\"recipient_ref\":\"email:$RECIPIENT\",\"min_score\":0,\"max_candidates\":1,\"interval_hours\":24,\"quiet_hours\":{\"timezone\":\"UTC\",\"start\":\"$START_HHMM\",\"end\":\"$END_HHMM\"}}" >"$ARTIFACT_DIR/quiet-schedule.json"
QUIET_SCHEDULE_ID="$(node -e 'const fs=require("fs"); const j=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); process.stdout.write(j.id)' "$ARTIFACT_DIR/quiet-schedule.json")"
"$ARCWELL_BIN" worker run-once --max-jobs 3 >"$ARTIFACT_DIR/worker-quiet.json"
"$ARCWELL_BIN" digest-alert-ticks --json "{\"schedule_id\":\"$QUIET_SCHEDULE_ID\"}" >"$ARTIFACT_DIR/quiet-ticks.json"
"$ARCWELL_BIN" digest-candidate-deliveries >"$ARTIFACT_DIR/deliveries-after-quiet.json"
"$ARCWELL_BIN" source-card search "credential health snapshot" >"$ARTIFACT_DIR/source-cards-after-quiet.json"

log "validating proof artifacts"
node - "$ARTIFACT_DIR" "$PROOF_ROOT" "$SCHEDULE_ID" "$QUIET_SCHEDULE_ID" "$SENTINEL_TOKEN" "$RECIPIENT" <<'NODE'
const fs = require("fs");
const path = require("path");
const [artifactDir, proofRoot, scheduleId, quietScheduleId, sentinelToken, recipient] = process.argv.slice(2);
const read = (name) => JSON.parse(fs.readFileSync(path.join(artifactDir, name), "utf8"));
const readJsonl = (name) => {
  const file = path.join(artifactDir, name);
  if (!fs.existsSync(file) || fs.statSync(file).size === 0) return [];
  return fs.readFileSync(file, "utf8").trim().split(/\n/).filter(Boolean).map((line) => JSON.parse(line));
};
function assert(condition, message, detail) {
  if (!condition) {
    console.error(`FAIL: ${message}`);
    if (detail !== undefined) console.error(JSON.stringify(detail, null, 2));
    process.exit(1);
  }
}

const health = read("secret-health-before.json");
const first = read("worker-first.json");
const second = read("worker-second.json");
const ticks = read("ticks-after-first.json");
const ticksSecond = read("ticks-after-second.json");
const candidates = read("candidates-after-first.json");
const deliveries = read("deliveries-after-first.json");
const cards = read("source-cards-after-first.json");
const quietWorker = read("worker-quiet.json");
const quietTicks = read("quiet-ticks.json");
const deliveriesAfterQuiet = read("deliveries-after-quiet.json");
const cardsAfterQuiet = read("source-cards-after-quiet.json");
const providerRequests = readJsonl("email-provider-requests.jsonl");

const xBearer = health.find((item) => item.name === "X_BEARER_TOKEN");
assert(xBearer && xBearer.status === "expiring_soon", "X bearer should be expiring soon", xBearer);
assert(first.digest_alert_schedule && first.digest_alert_schedule.enqueued === 1, "first worker should enqueue reminder schedule", first);
assert(first.processed === 1 && first.completed === 1, "first worker should process one completed reminder job", first);
const job = first.jobs.find((item) => item.kind === "digest_scheduled_alert");
assert(job && job.result_json && job.result_json.status === "sent", "reminder job should send", first.jobs);
assert(ticks.length === 1 && ticks[0].schedule_id === scheduleId && ticks[0].status === "sent", "sent tick should belong to reminder schedule", ticks);
assert(ticks[0].candidate_ids.length === 1, "sent reminder tick should record generated candidate", ticks[0]);
assert(ticks[0].delivery_ids.length === 1, "sent reminder tick should record delivery", ticks[0]);
const candidateId = ticks[0].candidate_ids[0];
const candidate = candidates.find((item) => item.id === candidateId);
assert(candidate && candidate.topic === "Arcwell credential health reminder", "reminder candidate should be generated", candidate);
assert(candidate.review_status === "approved" && candidate.reviewed_by === "arcwell-credential-reminder", "reminder candidate should be policy-approved by credential reviewer", candidate);
assert(cards.length === 1 && cards[0].provider === "arcwell" && cards[0].source_type === "credential_health", "one internal credential health source card should be written", cards);
assert(deliveries.length === 1 && deliveries[0].id === ticks[0].delivery_ids[0] && deliveries[0].status === "sent", "delivery ledger should have one sent delivery", deliveries);
assert(providerRequests.length === 1, "controlled email provider should receive exactly one request before quiet proof", providerRequests);
const providerBody = providerRequests[0].body;
for (const required of [
  "Arcwell credential reminder",
  "Bottom line",
  "What needs attention",
  "Why it matters",
  "Suggested follow-up",
  "Evidence quality",
  "X_BEARER_TOKEN",
  "raw secret values are intentionally omitted",
]) {
  assert(providerBody.includes(required), `provider email body missing ${required}`, providerBody);
}
assert(!providerBody.includes(sentinelToken), "sentinel bearer token leaked to email provider", providerBody);
const serialized = JSON.stringify({ health, first, ticks, candidates, deliveries, cards, providerRequests, quietWorker, quietTicks, deliveriesAfterQuiet, cardsAfterQuiet });
assert(!serialized.includes(sentinelToken), "sentinel bearer token leaked into proof artifacts");
assert(second.processed === 0, "duplicate worker pass should not create another due reminder tick", second);
assert(ticksSecond.length === 1, "duplicate pass should leave one reminder tick", ticksSecond);
assert(quietWorker.processed === 1 && quietWorker.deferred === 1, "quiet-hours worker should defer one job", quietWorker);
assert(quietTicks.length === 1 && quietTicks[0].schedule_id === quietScheduleId && quietTicks[0].status === "deferred", "quiet reminder tick should defer", quietTicks);
assert(quietTicks[0].candidate_ids.length === 0 && quietTicks[0].delivery_ids.length === 0, "quiet tick should not materialize or deliver", quietTicks[0]);
assert(deliveriesAfterQuiet.length === 1, "quiet proof must not create an extra delivery", deliveriesAfterQuiet);
assert(cardsAfterQuiet.length === 1, "quiet proof must not create an extra credential source card", cardsAfterQuiet);
assert(readJsonl("email-provider-requests.jsonl").length === 1, "quiet proof must not send another provider request");

const proofPacket = {
  proof_name: "credential-reminder-scheduled-proof",
  proof_level: "Local/controlled-provider scheduled outbound proof; not live external recurrence",
  proof_root: proofRoot,
  arcwell_home: process.env.ARCWELL_HOME,
  recipient,
  schedule_id: scheduleId,
  quiet_schedule_id: quietScheduleId,
  candidate_id: candidateId,
  source_card_id: cards[0].id,
  sent_tick_id: ticks[0].id,
  sent_delivery_id: deliveries[0].id,
  provider_requests: providerRequests.length,
  gates: {
    expiring_secret_detected: true,
    active_x_bookmark_schedule_present: true,
    source_card_written: true,
    human_readable_body: true,
    policy_auto_approval_required: true,
    recipient_authorization_required: true,
    delivery_ledger_sent: true,
    duplicate_suppression: true,
    quiet_hours_no_materialization_or_send: true,
    sentinel_secret_redacted: true,
  },
  remaining_risk: [
    "This proof uses a controlled local Cloudflare Email endpoint, not a real external inbox.",
    "It does not prove provider-side X scope introspection or revoked-token detection.",
    "It does not prove multi-day launchd/systemd recurrence.",
  ],
};
fs.writeFileSync(path.join(artifactDir, "proof-packet.json"), `${JSON.stringify(proofPacket, null, 2)}\n`);
console.log(JSON.stringify(proofPacket, null, 2));
NODE

printf '\n'
log "scheduled credential reminder proof passed"
log "proof packet: $ARTIFACT_DIR/proof-packet.json"
