#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DB="${ARCWELL_GITHUB_RATE_LIMIT_RECOVERY_DB:-${ARCWELL_HOME:-$HOME/.arcwell}/arcwell.sqlite3}"
RUN_STAMP="${ARCWELL_GITHUB_RATE_LIMIT_RECOVERY_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
PROOF_ROOT="${ARCWELL_GITHUB_RATE_LIMIT_RECOVERY_PROOF_DIR:-$REPO_ROOT/.arcwell-dev/proofs/wiki-github-rate-limit-recovery-$RUN_STAMP}"
ARTIFACT_DIR="$PROOF_ROOT/artifacts"
ARCWELL_BIN="${ARCWELL_BIN:-$REPO_ROOT/target/debug/arcwell}"
if [ ! -x "$ARCWELL_BIN" ]; then
  ARCWELL_BIN="$(command -v arcwell || true)"
fi

APPLY=0
MAX_SOURCES=10
LIMIT=2

usage() {
  cat <<'USAGE'
Usage: scripts/wiki-github-rate-limit-recovery [--apply] [--max-sources N] [--limit N] [--db PATH]

Find active GitHub owner watch sources whose source_health row is still
rate_limited and due for retry. By default this is dry-run only.

When --apply is set, runs:
  arcwell wiki run-github-owner --limit <N> <owner>

This script does not mark source-health rows healthy itself. Recovery only
happens if the existing GitHub owner adapter succeeds.
USAGE
}

while [ $# -gt 0 ]; do
  case "$1" in
    --apply)
      APPLY=1
      shift
      ;;
    --max-sources)
      MAX_SOURCES="${2:-}"
      shift 2
      ;;
    --limit)
      LIMIT="${2:-}"
      shift 2
      ;;
    --db)
      DB="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "BLOCKED: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

for value_name in MAX_SOURCES LIMIT; do
  value="${!value_name}"
  case "$value" in
    ''|*[!0-9]*)
      echo "BLOCKED: --${value_name,,} must be a positive integer" >&2
      exit 2
      ;;
  esac
  if [ "$value" -lt 1 ]; then
    echo "BLOCKED: --${value_name,,} must be >= 1" >&2
    exit 2
  fi
done

for required in python3 sqlite3 jq; do
  if ! command -v "$required" >/dev/null 2>&1; then
    echo "BLOCKED: $required is required." >&2
    exit 2
  fi
done

if [ ! -f "$DB" ]; then
  echo "BLOCKED: Arcwell DB not found: $DB" >&2
  exit 2
fi

if [ "$APPLY" -eq 1 ] && { [ -z "${ARCWELL_BIN:-}" ] || [ ! -x "$ARCWELL_BIN" ]; }; then
  echo "BLOCKED: arcwell binary not available for --apply" >&2
  exit 2
fi

mkdir -p "$ARTIFACT_DIR"

python3 - "$DB" "$ARTIFACT_DIR/selected-sources.json" "$ARTIFACT_DIR/selected-sources.csv" "$MAX_SOURCES" <<'PY'
import csv
import json
import sqlite3
import sys
from datetime import datetime, timezone
from pathlib import Path

db = Path(sys.argv[1])
json_out = Path(sys.argv[2])
csv_out = Path(sys.argv[3])
max_sources = int(sys.argv[4])
now = datetime.now(timezone.utc).isoformat()

conn = sqlite3.connect(str(db))
conn.row_factory = sqlite3.Row
rows = []
for row in conn.execute(
    """
    SELECT ws.locator, ws.label, ws.cadence,
           sh.key AS source_health_key, sh.status AS health_status,
           sh.last_success_at, sh.last_failure_at, sh.next_run_at,
           sh.updated_at, sh.last_error
    FROM watch_sources ws
    JOIN source_health sh
      ON sh.source_kind = ws.source_kind
     AND sh.locator = ws.locator
    WHERE ws.status = 'active'
      AND ws.source_kind = 'github_owner'
      AND sh.provider = 'github'
      AND sh.status = 'rate_limited'
      AND (sh.next_run_at IS NULL OR sh.next_run_at <= ?1)
    ORDER BY COALESCE(sh.last_failure_at, ''), lower(ws.locator)
    """,
    (now,),
):
    active_job = conn.execute(
        """
        SELECT id, status FROM wiki_jobs
        WHERE kind = 'github_owner'
          AND status IN ('pending', 'running', 'deferred')
          AND json_extract(input_json, '$.owner') = ?1
        ORDER BY updated_at DESC LIMIT 1
        """,
        (row["locator"],),
    ).fetchone()
    rows.append({
        "source_kind": "github_owner",
        "locator": row["locator"],
        "label": row["label"],
        "cadence": row["cadence"],
        "source_health_key": row["source_health_key"],
        "health_status": row["health_status"],
        "last_success_at": row["last_success_at"],
        "last_failure_at": row["last_failure_at"],
        "next_run_at": row["next_run_at"],
        "updated_at": row["updated_at"],
        "active_job_id": active_job["id"] if active_job else "",
        "active_job_status": active_job["status"] if active_job else "",
        "eligible_for_apply": not bool(active_job),
        "last_error": row["last_error"],
    })

selected = [row for row in rows if row["eligible_for_apply"]][:max_sources]
payload = {
    "generated_at": now,
    "total_due_rate_limited_rows": len(rows),
    "eligible_without_active_job": sum(1 for row in rows if row["eligible_for_apply"]),
    "selected_count": len(selected),
    "selected": selected,
    "skipped_active_jobs": [row for row in rows if not row["eligible_for_apply"]],
}
json_out.write_text(json.dumps(payload, indent=2), encoding="utf-8")

fields = [
    "source_kind", "locator", "label", "cadence", "source_health_key",
    "health_status", "last_success_at", "last_failure_at", "next_run_at",
    "updated_at", "active_job_id", "active_job_status",
    "eligible_for_apply", "last_error",
]
with csv_out.open("w", newline="", encoding="utf-8") as handle:
    writer = csv.DictWriter(handle, fieldnames=fields)
    writer.writeheader()
    for row in rows:
        writer.writerow(row)
print(json.dumps({
    "total_due_rate_limited_rows": len(rows),
    "eligible_without_active_job": payload["eligible_without_active_job"],
    "selected_count": len(selected),
}, indent=2))
PY

RESULTS_JSONL="$ARTIFACT_DIR/results.jsonl"
RESULTS_ERR="$ARTIFACT_DIR/results.err"
: >"$RESULTS_JSONL"
: >"$RESULTS_ERR"

if [ "$APPLY" -eq 1 ]; then
  python3 - "$ARTIFACT_DIR/selected-sources.json" "$ARCWELL_BIN" "$LIMIT" "$RESULTS_JSONL" "$RESULTS_ERR" <<'PY'
import json
import subprocess
import sys
from pathlib import Path

plan = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
arcwell = sys.argv[2]
limit = sys.argv[3]
jsonl = Path(sys.argv[4])
err = Path(sys.argv[5])

with jsonl.open("a", encoding="utf-8") as out, err.open("a", encoding="utf-8") as err_out:
    for source in plan["selected"]:
        cmd = [arcwell, "wiki", "run-github-owner", "--limit", limit, source["locator"]]
        proc = subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        result = {
            "source_kind": source["source_kind"],
            "locator": source["locator"],
            "command": cmd,
            "returncode": proc.returncode,
        }
        if proc.stdout.strip():
            try:
                result["stdout_json"] = json.loads(proc.stdout)
            except Exception:
                result["stdout"] = proc.stdout[-4000:]
        if proc.stderr.strip():
            result["stderr"] = proc.stderr[-4000:]
            err_out.write(f"## {' '.join(cmd)}\n{proc.stderr}\n")
        out.write(json.dumps(result) + "\n")
PY
fi

python3 - "$DB" "$ARTIFACT_DIR/selected-sources.json" "$ARTIFACT_DIR/post-source-health.json" <<'PY'
import json
import sqlite3
import sys
from pathlib import Path

db = Path(sys.argv[1])
plan = json.loads(Path(sys.argv[2]).read_text(encoding="utf-8"))
out = Path(sys.argv[3])
conn = sqlite3.connect(str(db))
conn.row_factory = sqlite3.Row
rows = []
for source in plan["selected"]:
    row = conn.execute(
        """
        SELECT key, provider, source_kind, locator, status,
               last_success_at, last_failure_at, last_error, next_run_at, updated_at
        FROM source_health
        WHERE key = ?1
        """,
        (source["source_health_key"],),
    ).fetchone()
    rows.append(dict(row) if row else {"key": source["source_health_key"], "missing": True})
out.write_text(json.dumps(rows, indent=2), encoding="utf-8")
PY

jq \
  --arg proof_root "$PROOF_ROOT" \
  --arg db "$DB" \
  --argjson apply "$APPLY" \
  --argjson limit "$LIMIT" \
  --slurpfile selected "$ARTIFACT_DIR/selected-sources.json" \
  --slurpfile post "$ARTIFACT_DIR/post-source-health.json" \
  '{
    ok: true,
    proof_root: $proof_root,
    db: $db,
    applied: ($apply == 1),
    per_owner_limit: $limit,
    selected: $selected[0],
    post_source_health: $post[0],
    non_claims: [
      "does not write source-health directly",
      "does not retry rows whose next_run_at is in the future",
      "does not process non-GitHub sources"
    ]
  }' \
  /dev/null >"$ARTIFACT_DIR/proof-packet.json"

cat >"$PROOF_ROOT/proof.md" <<EOF
# Wiki GitHub Rate-Limit Recovery Proof

Generated: \`$(date -u +%Y-%m-%dT%H:%M:%SZ)\`

- DB: \`$DB\`
- Apply: \`$APPLY\`
- Max sources: \`$MAX_SOURCES\`
- Per-owner limit: \`$LIMIT\`

Artifacts:
- \`artifacts/selected-sources.json\`
- \`artifacts/selected-sources.csv\`
- \`artifacts/results.jsonl\`
- \`artifacts/results.err\`
- \`artifacts/post-source-health.json\`
- \`artifacts/proof-packet.json\`

This proof only covers active due GitHub owner source-health rows in
\`rate_limited\`. The script does not change health state except through the
existing \`arcwell wiki run-github-owner\` adapter.
EOF

echo "[wiki-github-rate-limit-recovery] proof root: $PROOF_ROOT"
jq '{total_due_rate_limited_rows, eligible_without_active_job, selected_count}' "$ARTIFACT_DIR/selected-sources.json"
if [ "$APPLY" -eq 0 ]; then
  echo "[wiki-github-rate-limit-recovery] dry run only; rerun with --apply to execute retries"
else
  echo "[wiki-github-rate-limit-recovery] applied"
fi
echo "[wiki-github-rate-limit-recovery] proof packet: $ARTIFACT_DIR/proof-packet.json"
