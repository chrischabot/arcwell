#!/usr/bin/env python3
"""Merge Arcwell wiki editorial decision ledgers."""

from __future__ import annotations

import argparse
import csv
import json
from datetime import UTC, datetime
from pathlib import Path


FIELDNAMES = [
    "reviewed_at",
    "page_id",
    "page_title",
    "decision",
    "reviewed_source_card_ids",
    "rationale",
    "follow_up",
]


def now_iso() -> str:
    return datetime.now(UTC).isoformat()


def split_semicolon(value: str) -> list[str]:
    return [part.strip() for part in (value or "").split(";") if part.strip()]


def source_key(value: str) -> tuple[str, ...]:
    return tuple(sorted(set(split_semicolon(value))))


def read_rows(path: Path) -> list[dict[str, str]]:
    with path.open(newline="", encoding="utf-8") as handle:
        rows = []
        for raw in csv.DictReader(handle):
            decision = (raw.get("decision") or "").strip()
            if decision not in {"hold", "reject"}:
                continue
            source_ids = (
                raw.get("reviewed_source_card_ids")
                or raw.get("source_card_ids")
                or raw.get("accepted_source_card_ids")
                or ""
            )
            normalized_sources = source_key(source_ids)
            if not raw.get("page_id") or not normalized_sources:
                continue
            rows.append({
                "reviewed_at": raw.get("reviewed_at") or "",
                "page_id": raw.get("page_id") or "",
                "page_title": raw.get("page_title") or "",
                "decision": decision,
                "reviewed_source_card_ids": ";".join(normalized_sources),
                "rationale": raw.get("rationale") or "",
                "follow_up": raw.get("follow_up") or "",
                "source_file": str(path),
            })
        return rows


def row_sort_key(row: dict[str, str]) -> tuple[str, str, str, str]:
    return (
        row.get("page_title") or "",
        row.get("page_id") or "",
        row.get("reviewed_source_card_ids") or "",
        row.get("decision") or "",
    )


def write_csv(path: Path, rows: list[dict[str, str]], fieldnames: list[str]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", newline="", encoding="utf-8") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames)
        writer.writeheader()
        for row in rows:
            writer.writerow({name: row.get(name, "") for name in fieldnames})


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Merge hold/reject editorial decision ledgers for wiki freshness suppression."
    )
    parser.add_argument("--output", required=True, type=Path)
    parser.add_argument("--summary", type=Path)
    parser.add_argument("--conflicts", type=Path)
    parser.add_argument("ledgers", nargs="+", type=Path)
    args = parser.parse_args()

    all_rows: list[dict[str, str]] = []
    missing_inputs: list[str] = []
    for ledger in args.ledgers:
        if not ledger.exists():
            missing_inputs.append(str(ledger))
            continue
        all_rows.extend(read_rows(ledger))

    by_key: dict[tuple[str, tuple[str, ...]], dict[str, str]] = {}
    duplicates = 0
    conflicts: list[dict[str, str]] = []
    for row in all_rows:
        key = (row["page_id"], source_key(row["reviewed_source_card_ids"]))
        existing = by_key.get(key)
        if not existing:
            by_key[key] = row
            continue
        duplicates += 1
        if existing["decision"] != row["decision"]:
            conflicts.append({
                "page_id": row["page_id"],
                "page_title": row.get("page_title") or existing.get("page_title") or "",
                "reviewed_source_card_ids": row["reviewed_source_card_ids"],
                "kept_decision": existing["decision"],
                "conflicting_decision": row["decision"],
                "kept_source_file": existing.get("source_file", ""),
                "conflicting_source_file": row.get("source_file", ""),
            })
        existing_time = existing.get("reviewed_at") or ""
        row_time = row.get("reviewed_at") or ""
        if row_time > existing_time:
            # Keep the newest metadata while preserving the first decision on conflicts.
            kept_decision = existing["decision"]
            by_key[key] = row
            if conflicts and kept_decision != row["decision"]:
                by_key[key]["decision"] = kept_decision

    merged_rows = sorted(by_key.values(), key=row_sort_key)
    write_csv(args.output, merged_rows, FIELDNAMES)
    if args.conflicts:
        write_csv(
            args.conflicts,
            conflicts,
            [
                "page_id",
                "page_title",
                "reviewed_source_card_ids",
                "kept_decision",
                "conflicting_decision",
                "kept_source_file",
                "conflicting_source_file",
            ],
        )

    summary = {
        "ok": not missing_inputs,
        "generated_at": now_iso(),
        "inputs": [str(path) for path in args.ledgers],
        "missing_inputs": missing_inputs,
        "input_rows": len(all_rows),
        "merged_rows": len(merged_rows),
        "duplicates": duplicates,
        "conflicts": len(conflicts),
        "output": str(args.output),
        "conflicts_csv": str(args.conflicts) if args.conflicts else "",
    }
    if args.summary:
        args.summary.parent.mkdir(parents=True, exist_ok=True)
        args.summary.write_text(json.dumps(summary, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    print(json.dumps(summary, indent=2, sort_keys=True))
    return 0 if summary["ok"] else 1


if __name__ == "__main__":
    raise SystemExit(main())
