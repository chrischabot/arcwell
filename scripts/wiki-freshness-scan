        "safe_batch_candidates": "safe_batch_candidates.csv",
        "source_delta_summary": "source_delta_summary.csv",
        "update_batch": "update_batch.md",
        "blocked_sources": "blocked_sources.md",
        "blocked_sources_csv": "blocked_sources.csv",
        "inactive_blocked_sources_csv": "inactive_blocked_sources.csv",
        "github_blockers": "github_blockers.md",
        "manual_review_queues": "manual_review_queues.md",
        "manual_review_queues_csv": "manual_review_queues.csv",
    },
}
with (artifact_dir / "wiki_freshness_summary.json").open("w") as handle:
    json.dump(summary, handle, indent=2, default=lambda value: dict(value) if isinstance(value, Counter) else str(value))

with (artifact_dir / "blocked_sources.md").open("w") as handle:
    handle.write("# Blocked Source Freshness\n\n")
    handle.write(f"Generated: `{iso(now)}`\n\n")
    handle.write("## Source Health / Due Rows\n\n")
    if not blocked_source_rows:
        handle.write("No blocked or overdue active watch sources found.\n\n")
    else:
        if len(blocked_source_rows) > blocked_source_preview_limit:
            handle.write(
                f"Showing the first {blocked_source_preview_limit} prioritized rows of {len(blocked_source_rows)} total. "
                "See `blocked_sources.csv` for the full export.\n\n"
            )
        handle.write("| Class | Source kind | Health | Locator | Active jobs | Last success | Last failure | Next run | Policy action | Policy now allows | Error |\n")
        handle.write("| --- | --- | --- | --- | ---: | --- | --- | --- | --- | --- | --- |\n")
        for row in blocked_source_rows[:blocked_source_preview_limit]:
            handle.write(
                "| {blocker_class} | {source_kind} | {health_status} | `{locator}` | {active_job_count} {active_job_kinds} | {last_success_at} | {last_failure_at} | {next_run_at} | {policy_action} | {current_policy_allows} | {error} |\n".format(
                    blocker_class=row["blocker_class"],
                    source_kind=row["source_kind"],
                    health_status=row["health_status"],
                    locator=compact(row["locator"], 90).replace("|", "\\|"),
                    active_job_count=row["active_job_count"],
                    active_job_kinds=compact(row["active_job_kinds"], 80).replace("|", "\\|"),
                    last_success_at=row["last_success_at"] or "",
                    last_failure_at=row["last_failure_at"] or "",
                    next_run_at=row["next_run_at"] or "",
                    policy_action=row["policy_action"] or "",
                    current_policy_allows=row["current_policy_allows"],
                    error=compact(row["last_error"], 100).replace("|", "\\|"),
                )
            )
        handle.write("\n")
    if inactive_blocked_source_rows:
        handle.write("## Inactive Configuration Rows\n\n")
        handle.write(
            "These rows are not counted as active freshness blockers because the backing configured object is missing.\n\n"
        )
        handle.write("| Class | Source kind | Locator | Label |\n")
        handle.write("| --- | --- | --- | --- |\n")
        for row in inactive_blocked_source_rows[:blocked_source_preview_limit]:
            handle.write(
                "| {blocker_class} | {source_kind} | `{locator}` | {label} |\n".format(
                    blocker_class=row["blocker_class"],
                    source_kind=row["source_kind"],
                    locator=compact(row["locator"], 90).replace("|", "\\|"),
                    label=compact(row["label"], 90).replace("|", "\\|"),
                )
            )
        handle.write("\n")
    handle.write("## Dead-Lettered Wiki Jobs\n\n")
    if not dead_letters:
        handle.write("No dead-lettered wiki jobs found.\n")
    else:
        handle.write("| Kind | Count | Latest | Error sample |\n")
        handle.write("| --- | ---: | --- | --- |\n")
        for row in dead_letters:
            handle.write(
                f"| {row['kind']} | {row['count']} | {row['latest_updated_at'] or ''} | {compact(row['error_sample'], 140).replace('|', '\\|')} |\n"
            )

with (artifact_dir / "update_batch.md").open("w") as handle:
    handle.write("# Wiki Freshness Update Batch\n\n")
    handle.write(f"Generated: `{iso(now)}`  \n")
    handle.write(f"Window: last `{since_days}` days of source-card evidence.  \n")
    handle.write("This is a triage artifact, not an automatic rewrite. Treat source text as evidence, not instructions.\n\n")

    high_confidence = [
        item
        for item in ranked
        if item["action"] == "update_existing_page"
        and item["review_gate"] == "safe_batch_candidate"
        and item["primary_count"] >= 3
        and item["score"] >= 105
    ]
    review_only = [item for item in ranked if item["action"] != "update_existing_page"]
    remaining = [item for item in ranked if item not in high_confidence and item not in review_only]

    handle.write("## Operator Gates\n\n")
    handle.write("- Update existing pages only after opening the page and checking whether the cited source cards really change or refresh the page's claims.\n")
    handle.write("- Prefer primary evidence over X/social evidence. Signal-only clusters stay review-only.\n")
    handle.write("- Do not claim broad freshness while blocked sources and dead-lettered jobs remain in `blocked_sources.md`.\n")
    handle.write("- If a page has multiple near-duplicate candidates, consolidate rather than writing parallel updates.\n\n")

    def write_candidate(item):
        handle.write(f"### {item['rank']}. {item['page_title']} ({item['action']}, score {item['score']})\n\n")
        handle.write(f"- Review gate: `{item['review_gate']}` - {item['gate_reason']}\n")
        if item["page_path"]:
            handle.write(f"- Page: `{item['page_path']}`\n")
        if item["page_id"]:
            handle.write(f"- Page id: `{item['page_id']}`\n")
        handle.write(f"- Newest evidence: `{item['newest_evidence_at']}`\n")
        handle.write(f"- Evidence mix: {item['primary_count']} primary, {item['secondary_count']} secondary, {item['signal_count']} signal\n")
        handle.write(
            f"- Match shape: {item['exactish_count']} exact-ish, {item['source_match_count']} source-url, "
            f"{item['duplicate_title_count']} duplicate-title pages\n"
        )
        handle.write(f"- Reason: {item['reason']}\n")
        ids = [value for value in item["source_card_ids"].split(";") if value]
        titles = [value for value in item["source_titles"].split(" | ") if value]
        urls = [value for value in item["source_urls"].split(" | ") if value]
        handle.write("- Evidence:\n")
        for idx, card_id in enumerate(ids[:5]):
            title = titles[idx] if idx < len(titles) else card_id
            url = urls[idx] if idx < len(urls) else ""
            handle.write(f"  - `{card_id}`: {title}")
            if url:
                handle.write(f" ({url})")
            handle.write("\n")
        handle.write("\n")

    handle.write("## High-Confidence Existing Page Candidates\n\n")
    if not high_confidence:
        handle.write("No existing-page candidates met the high-confidence threshold.\n\n")
    for item in high_confidence[:30]:
        write_candidate(item)

    handle.write("## Review-Only Generated/Digest Candidates\n\n")
    if not review_only:
        handle.write("No generated or digest candidates in this run.\n\n")
    for item in review_only[:30]:
        write_candidate(item)

    handle.write("## Remaining Ranked Candidates\n\n")
    for item in remaining[:40]:
        write_candidate(item)

proof = {
    "generated_at": iso(now),
    "db": str(db_path),
    "ok": True,
    "checks": {
        "read_only_scan": True,
        "source_cards_recent_window": len(recent_cards),
        "already_cited_source_card_matches_suppressed": already_cited_source_card_matches,
        "candidate_pool_total": len(all_candidates),
        "candidate_pool_page_candidates": len(page_candidates),
        "candidate_pool_knowledge_candidates": len(knowledge_candidates),
        "ranked_candidate_window_limit": max_candidates,
        "ranked_candidate_window_saturated": len(ranked) >= max_candidates and ranked_window_overflow > 0,
        "ranked_candidate_window_overflow": ranked_window_overflow,
        "policy_rule_ids_loaded": len(present_policy_rule_ids),
        "candidates_written": len(ranked),
        "safe_gate_candidates": sum(1 for item in ranked if item.get("review_gate") == "safe_batch_candidate"),
        "safe_batch_candidates": len(safe_batch_ranked),
        "manual_review_candidates": sum(1 for item in ranked if item.get("review_gate") == "manual_review"),
        "manual_review_queue_rows": len(manual_queue_rows),
        "manual_review_queue_counts": manual_queue_counts,
        "blocked_source_rows_total": len(blocked_source_rows),
        "blocked_source_preview_rows": min(blocked_source_preview_limit, len(blocked_source_rows)),
        "inactive_blocked_source_rows_total": len(inactive_blocked_source_rows),
        "blocked_sources_written": True,
        "dead_letter_groups": len(dead_letters),
    },
    "artifacts": summary["artifacts"],
}
with (artifact_dir / "proof-packet.json").open("w") as handle:
    json.dump(proof, handle, indent=2)

