    conn.execute("INSERT INTO cursors VALUES (?, ?, ?)", ("rss:good", "item-1", "2026-06-30T08:00:00Z"))
    conn.execute("INSERT INTO cursors VALUES (?, ?, ?)", ("github-owner:stale", "repo-1", "2026-06-27T08:00:00Z"))
    conn.execute(
        "INSERT INTO cursors VALUES (?, ?, ?)",
        ("rss:https://broken.example.com/feed.xml", "item-2", "2026-06-27T09:00:00Z"),
