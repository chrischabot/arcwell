    )
    conn.execute(
        "INSERT INTO source_cards VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
        (
            "src-1",
            "Recent Card",
            "https://example.com/recent",
            "rss",
