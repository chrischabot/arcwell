scripts/wiki-freshness-ops-snapshot \
  --db "$DB" \
  --proof-dir "$PROOF_DIR" \
  --proof-root "$WORKFLOW_ROOT" \
  --recent-hours 24 \
  --stale-hours 24 \
  --failure-limit 10 >/tmp/wiki-freshness-ops-snapshot-test-output.json

python3 - "$PROOF_DIR/wiki_freshness_ops_snapshot.json" <<'PY'
import json
import sys

summary = json.load(open(sys.argv[1], encoding="utf-8"))
assert summary["assessment"]["status"] == "hold", summary["assessment"]
assert summary["watch_sources"]["total"] == 4, summary["watch_sources"]
assert summary["source_health"]["attention_rows"] == 1, summary["source_health"]
assert summary["source_health"]["inactive_attention_rows"] == 1, summary["source_health"]
assert summary["source_health"]["stale_healthy_rows"] == 0, summary["source_health"]
assert summary["source_health"]["inactive_stale_healthy_rows"] == 1, summary["source_health"]
assert summary["source_health"]["recent_attention"][0]["watch_status"] == "active"
assert summary["source_health"]["recent_inactive_attention"][0]["watch_status"] == "paused"
assert summary["cursors"]["stale_rows"] == 1, summary["cursors"]
assert summary["cursors"]["inactive_stale_rows"] == 1, summary["cursors"]
assert summary["cursors"]["oldest_stale"][0]["watch_status"] == "active"
assert summary["cursors"]["oldest_inactive_stale"][0]["watch_status"] == "missing"
assert not any(
    row["key"] == "x:watch:QuietSource" for row in summary["cursors"]["oldest_stale"]
), summary["cursors"]
assert summary["source_cards"]["recent"] == 1, summary["source_cards"]
assert summary["decision_ledger"]["rows"] == 1, summary["decision_ledger"]
assert summary["latest_workflow"]["blocked_source_rows_total"] == 2, summary["latest_workflow"]
assert summary["latest_workflow"]["pending_decisions"] == 3, summary["latest_workflow"]
assert summary["artifacts"]["summary_md"].endswith("wiki_freshness_ops_snapshot.md")
PY

echo "wiki freshness ops snapshot test passed: $PROOF_DIR"
