        ),
    )
    conn.commit()

with open(workflow_summary, "w", encoding="utf-8") as handle:
    json.dump(
        {
            "generated_at": "2026-06-30T08:00:00Z",
            "scan": {
                "candidate_pool_total": 10,
                "candidate_count": 3,
                "manual_review_queue_rows": 3,
                "blocked_source_rows_total": 2,
                "blocked_source_classes": {"rate_limited": 1, "queued_due": 1},
                "safe_batch_candidates": 0,
            },
            "packets": {"packet_count": 3, "suppressed_reviewed_decisions": 1},
            "decisions": {
                "remaining_pending": 3,
                "update_existing_export_rows": 0,
                "decision_ledger_rows": 1,
            },
            "agenda": {
                "clean_update_candidates": 0,
                "source_verification_candidates": 1,
            },
            "artifacts": {"editorial_agenda": "fixture-agenda.md"},
        },
        handle,
    )
