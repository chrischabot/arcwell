#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ARCWELL_BIN="${ARCWELL_BIN:-$REPO_ROOT/target/debug/arcwell}"
if [ ! -x "$ARCWELL_BIN" ]; then
  ARCWELL_BIN="$(command -v arcwell || true)"
fi

if [ -z "${ARCWELL_BIN:-}" ] || [ ! -x "$ARCWELL_BIN" ]; then
  echo "BLOCKED: arcwell binary not found. Run: cargo build -p arcwell" >&2
  exit 2
fi

for required in jq sqlite3 python3; do
  if ! command -v "$required" >/dev/null 2>&1; then
    echo "BLOCKED: $required is required for the job weekly report delivery proof." >&2
    exit 2
  fi
done

RUN_STAMP="${ARCWELL_JOB_WEEKLY_DELIVERY_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
PROOF_ROOT="${ARCWELL_JOB_WEEKLY_DELIVERY_PROOF_DIR:-$REPO_ROOT/.arcwell-dev/proofs/job-weekly-report-delivery-proof-$RUN_STAMP}"
ARTIFACT_DIR="$PROOF_ROOT/artifacts"
export ARCWELL_HOME="${ARCWELL_JOB_WEEKLY_DELIVERY_HOME:-$PROOF_ROOT/home}"
DB="$ARCWELL_HOME/arcwell.sqlite3"
SCOPE="Controlled weekly report delivery proof"

mkdir -p "$ARTIFACT_DIR" "$ARCWELL_HOME"

log() {
  printf '[job-weekly-report-delivery-proof] %s\n' "$*"
}

PROVIDER_PID=""
cleanup() {
  if [ -n "${PROVIDER_PID:-}" ]; then
    kill "$PROVIDER_PID" >/dev/null 2>&1 || true
  fi
}
trap cleanup EXIT

fail() {
  printf '[job-weekly-report-delivery-proof] BLOCKED: %s\n' "$*" >&2
  exit 2
}

require_json_value() {
  local value="$1"
  local label="$2"
  if [ -z "$value" ] || [ "$value" = "null" ]; then
    fail "missing $label"
  fi
}

assert_json() {
  local file="$1"
  local filter="$2"
  local label="$3"
  if ! jq -e "$filter" "$file" >/dev/null; then
    fail "$label failed for $file"
  fi
}

assert_sql_count() {
  local sql="$1"
  local expected="$2"
  local label="$3"
  local actual
  actual="$(sqlite3 "$DB" "$sql")"
  if [ "$actual" != "$expected" ]; then
    fail "$label expected $expected, got $actual"
  fi
}

log "proof root: $PROOF_ROOT"
log "ARCWELL_HOME: $ARCWELL_HOME"

"$ARCWELL_BIN" job profile-add \
  --label "Chris Chabot" \
  --current-resume-source "proof-fixture:current-resume" \
  --linkedin-source "https://www.linkedin.com/in/chrischabot/" \
  --github-profile "https://github.com/chrischabot" \
  --blog-url "https://chabot.dev" \
  >"$ARTIFACT_DIR/profile.json"
PROFILE_ID="$(jq -r '.id // empty' "$ARTIFACT_DIR/profile.json")"
require_json_value "$PROFILE_ID" "profile id"

"$ARCWELL_BIN" job evidence-add "$PROFILE_ID" \
  --title "Open Cloud" \
  --evidence-type "github" \
  --visibility "public" \
  --summary "Public project showing cloud and developer-tooling work." \
  --proof-url "https://github.com/chrischabot/opencloud" \
  --source-date "2026-06-28" \
  --confidence "verified" \
  --tag "developer-tools" \
  --tag "agents" \
  --safe-application-text "Built public developer tooling around cloud workflows." \
  >"$ARTIFACT_DIR/evidence.json"
EVIDENCE_ID="$(jq -r '.id // empty' "$ARTIFACT_DIR/evidence.json")"
require_json_value "$EVIDENCE_ID" "evidence id"

"$ARCWELL_BIN" job role-add \
  --company "Example AI" \
  --role-title "Staff Agent Platform Engineer" \
  --canonical-url "https://example.com/careers/staff-agent-platform-engineer" \
  --source-family "company" \
  --source-url "https://example.com/careers/staff-agent-platform-engineer" \
  --source-confidence "canonical_confirmed" \
  --date-accessed "2026-06-29T08:00:00Z" \
  --posting-freshness "same_day" \
  --location "London or remote Europe" \
  --work-mode "hybrid_or_remote" \
  --company-stage-or-size "startup" \
  --role-seniority "staff" \
  --requirement "agent systems" \
  --requirement "developer tooling" \
  --implied-business-problem "The company needs reliable agent infrastructure for developers." \
  --why-they-might-need-user "Public work maps to agent and developer-tooling problems." \
  --evidence-card-id "$EVIDENCE_ID" \
  --cluster "agent-platform" \
  --current-status "live" \
  >"$ARTIFACT_DIR/role.json"
ROLE_ID="$(jq -r '.id // empty' "$ARTIFACT_DIR/role.json")"
require_json_value "$ROLE_ID" "role id"

"$ARCWELL_BIN" job score-add "$ROLE_ID" \
  --profile-id "$PROFILE_ID" \
  --role-fit 5 \
  --domain-fit 5 \
  --evidence-fit 5 \
  --geo-work-fit 5 \
  --stage-fit 4.5 \
  --practical-odds 4.5 \
  --interest-energy 5 \
  --evidence-card-id "$EVIDENCE_ID" \
  --explanation "Strong controlled fit fixture for weekly report delivery proof." \
  >"$ARTIFACT_DIR/score.json"

"$ARCWELL_BIN" job weekly-report "$PROFILE_ID" --scope "$SCOPE" >"$ARTIFACT_DIR/weekly-report.json"
REPORT_ID="$(jq -r '.id // empty' "$ARTIFACT_DIR/weekly-report.json")"
require_json_value "$REPORT_ID" "weekly report id"
assert_json "$ARTIFACT_DIR/weekly-report.json" '.body | contains("# Job Weekly Report")' "weekly report body"

"$ARCWELL_BIN" job weekly-report-delivery-prepare "$REPORT_ID" \
  --channel email \
  --subject job-proof@example.com \
  --target job-proof@example.com \
  --idempotency-key job-weekly-delivery-unauthorized \
  >"$ARTIFACT_DIR/delivery-unauthorized.json"
assert_json "$ARTIFACT_DIR/delivery-unauthorized.json" '.delivery.status == "blocked"' "unauthorized delivery status"
assert_json "$ARTIFACT_DIR/delivery-unauthorized.json" '.delivery.privacy_check_id == null' "unauthorized privacy skip"
assert_json "$ARTIFACT_DIR/delivery-unauthorized.json" '.channel_message == null and .delivery.channel_message_id == null' "unauthorized channel message"
assert_json "$ARTIFACT_DIR/delivery-unauthorized.json" '.delivery.error | contains("not authorized to send")' "unauthorized error"
assert_sql_count "SELECT COUNT(*) FROM channel_messages;" "0" "unauthorized channel message count"
assert_sql_count "SELECT COUNT(*) FROM channel_delivery_attempts;" "0" "unauthorized delivery attempt count"

"$ARCWELL_BIN" email authorize job-proof@example.com --send >"$ARTIFACT_DIR/email-authorization.json"
cat >"$ARCWELL_HOME/arcwell-policy.toml" <<'POLICY'
[[rules]]
id = "allow-job-weekly-report-email-send"
effect = "allow"
action = "channel.send"
package = "arcwell-email"
provider = "cloudflare_email"
source = "job_weekly_report_delivery"
channel = "email"
subject = "email:job-proof@example.com"
target = "job-proof@example.com"
reason = "allow controlled weekly job report email send"
priority = 10
POLICY

"$ARCWELL_BIN" job weekly-report-delivery-prepare "$REPORT_ID" \
  --channel email \
  --subject job-proof@example.com \
  --target job-proof@example.com \
  --idempotency-key job-weekly-delivery-prepared \
  >"$ARTIFACT_DIR/delivery-prepared.json"
MESSAGE_ID="$(jq -r '.delivery.channel_message_id // empty' "$ARTIFACT_DIR/delivery-prepared.json")"
PREPARED_DELIVERY_ID="$(jq -r '.delivery.id // empty' "$ARTIFACT_DIR/delivery-prepared.json")"
require_json_value "$MESSAGE_ID" "prepared channel message id"
require_json_value "$PREPARED_DELIVERY_ID" "prepared delivery id"
assert_json "$ARTIFACT_DIR/delivery-prepared.json" '.delivery.status == "prepared"' "prepared delivery status"
assert_json "$ARTIFACT_DIR/delivery-prepared.json" '.privacy_check.decision == "pass"' "prepared privacy pass"
assert_json "$ARTIFACT_DIR/delivery-prepared.json" '.channel_message.status == "prepared" and .channel_message.direction == "outgoing"' "prepared channel message"
assert_sql_count "SELECT COUNT(*) FROM channel_messages;" "1" "prepared channel message count"
assert_sql_count "SELECT COUNT(*) FROM channel_delivery_attempts;" "0" "prepared provider attempt count"

"$ARCWELL_BIN" job weekly-report-delivery-prepare "$REPORT_ID" \
  --channel email \
  --subject email:job-proof@example.com \
  --target email:job-proof@example.com \
  --idempotency-key job-weekly-delivery-prepared \
  >"$ARTIFACT_DIR/delivery-replay.json"
REPLAY_MESSAGE_ID="$(jq -r '.delivery.channel_message_id // empty' "$ARTIFACT_DIR/delivery-replay.json")"
if [ "$REPLAY_MESSAGE_ID" != "$MESSAGE_ID" ]; then
  fail "idempotent replay wrote a different channel message"
fi
assert_json "$ARTIFACT_DIR/delivery-replay.json" '.idempotent_replay == true' "prepared replay idempotency"
assert_sql_count "SELECT COUNT(*) FROM channel_messages;" "1" "replay channel message count"

PROVIDER_PORT_FILE="$ARTIFACT_DIR/mock-provider-port.txt"
PROVIDER_REQUEST_LOG="$ARTIFACT_DIR/mock-provider-request.jsonl"
python3 - "$PROVIDER_PORT_FILE" "$PROVIDER_REQUEST_LOG" <<'PY' &
import json
import sys
from http.server import BaseHTTPRequestHandler, HTTPServer

port_file, request_log = sys.argv[1], sys.argv[2]

class Handler(BaseHTTPRequestHandler):
    def do_POST(self):
        length = int(self.headers.get("content-length", "0") or "0")
        body = self.rfile.read(length).decode("utf-8", "replace")
        with open(request_log, "a", encoding="utf-8") as handle:
            handle.write(json.dumps({
                "method": "POST",
                "path": self.path,
                "authorization": self.headers.get("authorization"),
                "body": body,
            }) + "\n")
        payload = b'{"success":true,"result":{"id":"job_weekly_delivery_proof"}}'
        self.send_response(200)
        self.send_header("content-type", "application/json")
        self.send_header("content-length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload)

    def log_message(self, *_args):
        return

server = HTTPServer(("127.0.0.1", 0), Handler)
with open(port_file, "w", encoding="utf-8") as handle:
    handle.write(str(server.server_port))
server.handle_request()
PY
PROVIDER_PID="$!"
for _ in $(seq 1 50); do
  if [ -s "$PROVIDER_PORT_FILE" ]; then
    break
  fi
  sleep 0.1
done
PROVIDER_PORT="$(cat "$PROVIDER_PORT_FILE" 2>/dev/null || true)"
require_json_value "$PROVIDER_PORT" "mock provider port"
PROVIDER_API_BASE="http://127.0.0.1:$PROVIDER_PORT"

"$ARCWELL_BIN" job weekly-report-delivery-send "$PREPARED_DELIVERY_ID" \
  --email-account-id acct123 \
  --email-api-token TOKEN \
  --email-from agent@example.com \
  --api-base "$PROVIDER_API_BASE" \
  >"$ARTIFACT_DIR/delivery-sent.json"
for _ in $(seq 1 50); do
  if ! kill -0 "$PROVIDER_PID" >/dev/null 2>&1; then
    break
  fi
  sleep 0.1
done
if kill -0 "$PROVIDER_PID" >/dev/null 2>&1; then
  kill "$PROVIDER_PID" >/dev/null 2>&1 || true
  PROVIDER_PID=""
  fail "mock provider was not called by weekly-report-delivery-send"
fi
wait "$PROVIDER_PID" 2>/dev/null || true
PROVIDER_PID=""
assert_json "$ARTIFACT_DIR/delivery-sent.json" '.delivery.status == "sent"' "provider-send delivery status"
assert_json "$ARTIFACT_DIR/delivery-sent.json" '.channel_message.status == "sent"' "provider-send channel message status"
assert_json "$ARTIFACT_DIR/delivery-sent.json" '.channel_delivery_attempt.ok == true' "provider-send attempt ok"
assert_json "$ARTIFACT_DIR/delivery-sent.json" '.proof_level == "controlled_provider_delivery"' "provider-send proof level"
assert_sql_count "SELECT COUNT(*) FROM channel_delivery_attempts;" "1" "provider-send delivery attempt count"
assert_sql_count "SELECT COUNT(*) FROM channel_messages WHERE id = '$MESSAGE_ID' AND status = 'sent';" "1" "provider-send message persisted status"
if ! grep -q "/accounts/acct123/email/sending/send" "$PROVIDER_REQUEST_LOG"; then
  fail "mock provider request did not hit the expected Cloudflare Email path"
fi

"$ARCWELL_BIN" job weekly-report-delivery-send "$PREPARED_DELIVERY_ID" \
  --email-account-id acct123 \
  --email-api-token TOKEN \
  --email-from agent@example.com \
  --api-base "http://127.0.0.1:9" \
  >"$ARTIFACT_DIR/delivery-send-replay.json"
assert_json "$ARTIFACT_DIR/delivery-send-replay.json" '.idempotent_replay == true' "provider-send replay idempotency"
assert_json "$ARTIFACT_DIR/delivery-send-replay.json" '.channel_delivery_attempt.ok == true' "provider-send replay attempt reuse"
assert_sql_count "SELECT COUNT(*) FROM channel_delivery_attempts;" "1" "provider-send replay attempt count"

"$ARCWELL_BIN" job privacy-rule-add \
  --pattern "# Job Weekly Report" \
  --rule-type blocked_term \
  --severity block \
  --replacement-guidance "Do not deliver weekly reports from this proof home." \
  >"$ARTIFACT_DIR/privacy-rule.json"

"$ARCWELL_BIN" job weekly-report-delivery-prepare "$REPORT_ID" \
  --channel email \
  --subject job-proof@example.com \
  --target job-proof@example.com \
  --idempotency-key job-weekly-delivery-privacy-block \
  >"$ARTIFACT_DIR/delivery-privacy-blocked.json"
assert_json "$ARTIFACT_DIR/delivery-privacy-blocked.json" '.delivery.status == "blocked"' "privacy-blocked delivery status"
assert_json "$ARTIFACT_DIR/delivery-privacy-blocked.json" '.privacy_check.decision == "block"' "privacy-blocked decision"
assert_json "$ARTIFACT_DIR/delivery-privacy-blocked.json" '.channel_message == null and .delivery.channel_message_id == null' "privacy-blocked channel message"
assert_sql_count "SELECT COUNT(*) FROM channel_messages;" "1" "privacy-blocked channel message count"
assert_sql_count "SELECT COUNT(*) FROM channel_delivery_attempts;" "1" "privacy-blocked provider attempt count"

"$ARCWELL_BIN" job weekly-report-deliveries --report-id "$REPORT_ID" >"$ARTIFACT_DIR/deliveries.json"
assert_json "$ARTIFACT_DIR/deliveries.json" 'length == 3' "delivery ledger row count"
assert_json "$ARTIFACT_DIR/deliveries.json" '[.[] | select(.status == "sent")] | length == 1' "sent ledger count"
assert_json "$ARTIFACT_DIR/deliveries.json" '[.[] | select(.status == "blocked")] | length == 2' "blocked ledger count"

CHANNEL_MESSAGE_COUNT="$(sqlite3 "$DB" "SELECT COUNT(*) FROM channel_messages;")"
DELIVERY_ATTEMPT_COUNT="$(sqlite3 "$DB" "SELECT COUNT(*) FROM channel_delivery_attempts;")"
DELIVERY_ROW_COUNT="$(jq 'length' "$ARTIFACT_DIR/deliveries.json")"

jq -n \
  --arg proof_root "$PROOF_ROOT" \
  --arg arcwell_home "$ARCWELL_HOME" \
  --arg profile_id "$PROFILE_ID" \
  --arg report_id "$REPORT_ID" \
  --arg channel_message_count "$CHANNEL_MESSAGE_COUNT" \
  --arg delivery_attempt_count "$DELIVERY_ATTEMPT_COUNT" \
  --arg delivery_row_count "$DELIVERY_ROW_COUNT" \
  --slurpfile unauthorized "$ARTIFACT_DIR/delivery-unauthorized.json" \
  --slurpfile prepared "$ARTIFACT_DIR/delivery-prepared.json" \
  --slurpfile replay "$ARTIFACT_DIR/delivery-replay.json" \
  --slurpfile sent "$ARTIFACT_DIR/delivery-sent.json" \
  --slurpfile send_replay "$ARTIFACT_DIR/delivery-send-replay.json" \
  --slurpfile privacy_blocked "$ARTIFACT_DIR/delivery-privacy-blocked.json" \
  '{
    feature: "job_weekly_report_delivery_provider_send",
    status: "controlled_local_proof",
    proof_root: $proof_root,
    arcwell_home: $arcwell_home,
    profile_id: $profile_id,
    report_id: $report_id,
    user_visible_claim: "Arcwell can prepare a weekly job report for an authorized channel subject after privacy checks, then explicitly send the prepared message through a provider path that records a delivery attempt.",
    durable_state_written: [
      "job_candidate_profiles",
      "job_evidence_cards",
      "job_role_cards",
      "job_fit_scores",
      "job_weekly_reports",
      "channel_authorizations",
      "job_privacy_checks",
      "channel_messages",
      "channel_delivery_attempts",
      "job_weekly_report_deliveries"
    ],
    gates: {
      unauthorized_delivery: $unauthorized[0].delivery,
      prepared_delivery: $prepared[0].delivery,
      replay_idempotent: $replay[0].idempotent_replay,
      provider_sent_delivery: $sent[0].delivery,
      provider_send_attempt: $sent[0].channel_delivery_attempt,
      provider_send_replay_idempotent: $send_replay[0].idempotent_replay,
      privacy_blocked_delivery: $privacy_blocked[0].delivery
    },
    counts: {
      job_weekly_report_deliveries: ($delivery_row_count | tonumber),
      channel_messages: ($channel_message_count | tonumber),
      channel_delivery_attempts: ($delivery_attempt_count | tonumber)
    },
    non_claims: [
      "The provider API base was a loopback mock, not live Cloudflare Email or Telegram.",
      "No real external email or Telegram message was sent.",
      "No application packet was sent.",
      "No application status was changed.",
      "No Google Docs draft was created.",
      "No operational-home or recurrence behavior was proven.",
      "No live job-source freshness or market coverage was proven."
    ],
    next_actions: [
      "Use live provider delivery only after explicit user authorization, configured secrets, and a real recipient are in scope.",
      "Keep one-day radar freshness blocked until scripts/job-refresh-one-day-proof passes after the recorded ready_at_utc."
    ]
  }' >"$ARTIFACT_DIR/proof-packet.json"

log "proof packet: $ARTIFACT_DIR/proof-packet.json"
log "PASS"
