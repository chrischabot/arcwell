#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

RUN_STAMP="$(date -u +%Y%m%dT%H%M%SZ)-$$"
PROOF_ROOT="${ARCWELL_X_WATCH_CURATION_REAL_PROOF_DIR:-$REPO_ROOT/.arcwell-dev/proofs/x-watch-curation-real-home-pause-proof-$RUN_STAMP}"
ARTIFACT_DIR="$PROOF_ROOT/artifacts"
RAW_DIR="$PROOF_ROOT/raw"
BACKUP_DIR="$PROOF_ROOT/private-backup"
REAL_HOME="${ARCWELL_X_WATCH_CURATION_REAL_HOME:-${ARCWELL_HOME:-$HOME/.arcwell}}"
ARCWELL_BIN="${ARCWELL_BIN:-$REPO_ROOT/target/debug/arcwell}"
RULES_PATH="${ARCWELL_X_WATCH_CURATION_REVIEWED_RULES:-}"
REVIEWED_BY="${ARCWELL_X_WATCH_CURATION_REVIEWED_BY:-codex-x-watch-curation-real-home-approved}"
APPROVAL_TEXT="${ARCWELL_X_WATCH_CURATION_APPROVAL_TEXT:-Approve applying the 45 reviewed X watch excludes to the real home.}"

usage() {
  cat <<'USAGE'
Usage: scripts/x-watch-curation-real-home-pause-proof --rules reviewed-rules.json [--reviewed-by name]

Applies reviewed X watch manual rules and pause-only curation to the real
Arcwell home after explicit approval. The script creates a private SQLite
backup, validates that exactly the reviewed excludes are paused, and records a
proof packet. It does not delete watch sources.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --rules)
      RULES_PATH="${2:?missing value for --rules}"
      shift 2
      ;;
    --reviewed-by)
      REVIEWED_BY="${2:?missing value for --reviewed-by}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

log() {
  printf '[x-watch-curation-real-home-pause-proof] %s\n' "$*"
}

fail() {
  printf '[x-watch-curation-real-home-pause-proof] BLOCKED: %s\n' "$*" >&2
  exit 1
}

[[ -n "$RULES_PATH" ]] || fail "missing --rules reviewed manual-rule JSON path"
[[ -f "$RULES_PATH" ]] || fail "reviewed rules file does not exist: $RULES_PATH"
[[ -d "$REAL_HOME" ]] || fail "real Arcwell home does not exist: $REAL_HOME"
[[ -f "$REAL_HOME/arcwell.sqlite3" ]] || fail "real Arcwell SQLite DB does not exist: $REAL_HOME/arcwell.sqlite3"

mkdir -p "$ARTIFACT_DIR" "$RAW_DIR" "$BACKUP_DIR"

log "proof root: $PROOF_ROOT"
log "real home: $REAL_HOME"
log "reviewed rules: $RULES_PATH"
cp "$RULES_PATH" "$ARTIFACT_DIR/reviewed-rules.json"

log "building arcwell CLI"
cargo build -p arcwell >"$ARTIFACT_DIR/cargo-build.log" 2>&1

log "running targeted tests"
cargo test -p arcwell-core x_watch_curation -- --nocapture \
  >"$ARTIFACT_DIR/x-watch-curation-tests.log" 2>&1
cargo test -p arcwell-core x_watch_manual_rule -- --nocapture \
  >"$ARTIFACT_DIR/x-watch-manual-rule-tests.log" 2>&1
cargo test -p arcwell-core proof -- --nocapture \
  >"$ARTIFACT_DIR/proof-tests.log" 2>&1
cargo fmt -- --check >"$ARTIFACT_DIR/cargo-fmt-check.log" 2>&1

capture_state() {
  local output="$1"
  python3 - "$REAL_HOME/arcwell.sqlite3" >"$output" <<'PY'
import hashlib, json, sqlite3, sys
db = sys.argv[1]
conn = sqlite3.connect(db)
rows = conn.execute(
    "SELECT id, locator, status, label, cadence, metadata_json FROM watch_sources WHERE source_kind='x_handle' ORDER BY id"
).fetchall()
payload = json.dumps(rows, sort_keys=True, separators=(",", ":"))
status_counts = dict(conn.execute(
    "SELECT status, COUNT(*) FROM watch_sources WHERE source_kind='x_handle' GROUP BY status ORDER BY status"
).fetchall())
print(json.dumps({
    "status_counts": status_counts,
    "total_x_handle_sources": len(rows),
    "row_checksum": hashlib.sha256(payload.encode()).hexdigest(),
    "rows": [
        {
            "id": row[0],
            "locator": row[1],
            "status": row[2],
            "label": row[3],
            "cadence": row[4],
            "metadata_sha256": hashlib.sha256((row[5] or "").encode()).hexdigest(),
        }
        for row in rows
    ],
    "manual_rule_count": conn.execute("SELECT COUNT(*) FROM x_watch_manual_rules").fetchone()[0],
    "curation_run_count": conn.execute("SELECT COUNT(*) FROM x_watch_curation_runs").fetchone()[0],
    "restore_snapshot_count": conn.execute("SELECT COUNT(*) FROM x_watch_restore_snapshots").fetchone()[0],
}, indent=2, sort_keys=True))
PY
}

log "capturing real-home baseline"
capture_state "$RAW_DIR/real-before.json"

log "creating private SQLite backup"
python3 - "$REAL_HOME/arcwell.sqlite3" "$BACKUP_DIR/arcwell-before-pause.sqlite3" <<'PY'
import pathlib, sqlite3, sys
src_path = pathlib.Path(sys.argv[1])
dst_path = pathlib.Path(sys.argv[2])
dst_path.parent.mkdir(parents=True, exist_ok=True)
src = sqlite3.connect(src_path)
dst = sqlite3.connect(dst_path)
src.backup(dst)
dst.close()
src.close()
PY
shasum -a 256 "$BACKUP_DIR/arcwell-before-pause.sqlite3" >"$ARTIFACT_DIR/private-backup-sha256.txt"

log "dry-running reviewed manual-rule import in real home"
"$ARCWELL_BIN" --home "$REAL_HOME" x import-watch-manual-rules \
  --path "$ARTIFACT_DIR/reviewed-rules.json" \
  --reviewed-by "$REVIEWED_BY" \
  --dry-run >"$RAW_DIR/import-dry-run.json"

log "applying reviewed manual rules in real home"
"$ARCWELL_BIN" --home "$REAL_HOME" x import-watch-manual-rules \
  --path "$ARTIFACT_DIR/reviewed-rules.json" \
  --reviewed-by "$REVIEWED_BY" \
  --apply >"$RAW_DIR/import-apply.json"

log "dry-running curation after reviewed rules in real home"
"$ARCWELL_BIN" --home "$REAL_HOME" x curate-watch-sources --dry-run \
  >"$RAW_DIR/curation-dry-run.json"

log "applying pause-only curation in real home"
"$ARCWELL_BIN" --home "$REAL_HOME" x curate-watch-sources --apply --mode pause-only \
  >"$RAW_DIR/pause-apply.json"

log "capturing real-home after state"
capture_state "$RAW_DIR/real-after.json"

log "validating real-home pause invariants"
python3 - "$ARTIFACT_DIR" "$RAW_DIR" "$PROOF_ROOT" "$REVIEWED_BY" "$APPROVAL_TEXT" "$BACKUP_DIR/arcwell-before-pause.sqlite3" <<'PY'
import hashlib, json, pathlib, sys
artifacts = pathlib.Path(sys.argv[1])
raw = pathlib.Path(sys.argv[2])
proof_root = pathlib.Path(sys.argv[3])
reviewed_by = sys.argv[4]
approval_text = sys.argv[5]
backup_path = pathlib.Path(sys.argv[6])

def load(path):
    return json.loads((raw / path).read_text())

def assert_true(condition, message):
    if not condition:
        raise SystemExit(message)

rules = json.loads((artifacts / "reviewed-rules.json").read_text())
before = load("real-before.json")
after = load("real-after.json")
import_dry = load("import-dry-run.json")
import_apply = load("import-apply.json")
curation_dry = load("curation-dry-run.json")
pause_apply = load("pause-apply.json")

exclude_handles = sorted(
    rule["handle"].lstrip("@").lower()
    for rule in rules
    if rule["decision"] == "manual_always_exclude"
)
keep_handles = sorted(
    rule["handle"].lstrip("@").lower()
    for rule in rules
    if rule["decision"] == "manual_always_keep"
)
assert_true(exclude_handles, "reviewed rules must contain manual_always_exclude rows")
assert_true(backup_path.exists(), "private SQLite backup is missing")
assert_true(import_dry["dry_run"] is True, "manual-rule dry run did not report dry_run")
assert_true(import_dry["rejected"] == 0, f"manual-rule dry run rejected rows: {import_dry}")
assert_true(import_dry["imported"] == 0 and import_dry["updated"] == 0, "manual-rule dry run wrote rows")
assert_true(import_apply["dry_run"] is False, "manual-rule apply did not report apply mode")
assert_true(import_apply["rejected"] == 0, f"manual-rule apply rejected rows: {import_apply}")
assert_true(import_apply["seen"] == len(rules), "manual-rule apply did not see every reviewed rule")
assert_true(
    import_apply["imported"] + import_apply["updated"] == len(rules),
    f"manual-rule apply did not write every reviewed rule: {import_apply}",
)

before_rows = {row["locator"].lower(): row for row in before["rows"]}
after_rows = {row["locator"].lower(): row for row in after["rows"]}
assert_true(before["total_x_handle_sources"] == after["total_x_handle_sources"], "watch-source total changed")
assert_true(set(before_rows) == set(after_rows), "watch-source locator set changed")

changed = []
for handle, before_row in before_rows.items():
    after_row = after_rows[handle]
    if before_row != after_row:
        changed.append({
            "handle": handle,
            "before": before_row,
            "after": after_row,
        })
changed_status = [
    row for row in changed
    if row["before"]["status"] != row["after"]["status"]
]
unexpected = [
    row for row in changed_status
    if row["handle"] not in exclude_handles
    or row["before"]["status"] != "active"
    or row["after"]["status"] != "paused"
]
assert_true(not unexpected, f"unexpected watch-source status changes: {unexpected[:5]}")
assert_true(
    sorted(row["handle"] for row in changed_status) == exclude_handles,
    "status changes did not exactly match reviewed exclude handles",
)
assert_true(
    after["status_counts"].get("active", 0) == before["status_counts"].get("active", 0) - len(exclude_handles),
    "active count did not decrease by reviewed exclude count",
)
assert_true(
    after["status_counts"].get("paused", 0) == before["status_counts"].get("paused", 0) + len(exclude_handles),
    "paused count did not increase by reviewed exclude count",
)

applied = [decision for decision in pause_apply["decisions"] if decision.get("applied_at")]
assert_true(pause_apply["run"]["paused_count"] == len(exclude_handles), "paused_count mismatch")
assert_true(len(applied) == len(exclude_handles), "applied decision count mismatch")
for decision in applied:
    assert_true(decision["handle"].lower() in exclude_handles, f"non-reviewed handle paused: {decision}")
    assert_true(decision["recommendation"] == "paused_excluded", f"paused decision was not an exclude: {decision}")
for handle in keep_handles:
    assert_true(after_rows[handle]["status"] == "active", f"manual keep handle not active after apply: {handle}")
    keep_decision = next(
        (decision for decision in pause_apply["decisions"] if decision["handle"].lower() == handle),
        None,
    )
    assert_true(keep_decision is not None, f"manual keep handle missing curation decision: {handle}")
    assert_true(not keep_decision.get("applied_at"), f"manual keep handle was applied/paused: {keep_decision}")

summary = {
    "proof_name": "x-watch-curation-real-home-pause-proof",
    "proof_level": "real_home_pause_only_proof",
    "reviewed_by": reviewed_by,
    "approval_text": approval_text,
    "reviewed_rule_count": len(rules),
    "manual_keep_count": len(keep_handles),
    "manual_exclude_count": len(exclude_handles),
    "private_backup": {
        "path": str(backup_path),
        "sha256": hashlib.sha256(backup_path.read_bytes()).hexdigest(),
        "included_in_clean_packet": False,
    },
    "real_home": {
        "total_x_handle_sources": before["total_x_handle_sources"],
        "status_before": before["status_counts"],
        "status_after": after["status_counts"],
        "changed_status_count": len(changed_status),
        "paused_handles": sorted(row["handle"] for row in changed_status),
        "row_checksum_before": before["row_checksum"],
        "row_checksum_after": after["row_checksum"],
    },
    "manual_rule_import": {
        "dry_run_seen": import_dry["seen"],
        "dry_run_rejected": import_dry["rejected"],
        "apply_seen": import_apply["seen"],
        "apply_imported": import_apply["imported"],
        "apply_updated": import_apply["updated"],
        "apply_rejected": import_apply["rejected"],
    },
    "curation": {
        "dry_run_id": curation_dry["run"]["id"],
        "pause_apply_run_id": pause_apply["run"]["id"],
        "paused_count": pause_apply["run"]["paused_count"],
        "counts": pause_apply["counts"],
    },
    "non_claims": [
        "This is not proof that X provider quota pressure improved.",
        "This is not scheduled or operational curation proof.",
        "This is not proof that every possible relevant X account is in the keep set.",
        "This does not delete any watch source."
    ]
}
(artifacts / "real-home-pause-summary.json").write_text(json.dumps(summary, indent=2, sort_keys=True) + "\n")
(artifacts / "real-home-pause-validation.json").write_text(json.dumps({
    "status": "passed",
    "checks": [
        "private SQLite backup created before mutation",
        "manual-rule dry-run wrote no rows",
        "manual-rule apply wrote every reviewed row",
        "watch-source total count unchanged",
        "status changes exactly matched manual_always_exclude handles",
        "manual_always_keep handles remained active",
        "pause-only apply did not delete watch sources"
    ],
    "run_id": pause_apply["run"]["id"],
    "rule_counts": {
        "keep": len(keep_handles),
        "exclude": len(exclude_handles)
    }
}, indent=2, sort_keys=True) + "\n")

packet = {
    "proof_name": "x-watch-curation-real-home-pause-proof",
    "proof_level": "real_home_pause_only_proof",
    "proof_root": str(proof_root),
    "feature": "M1 real-home reversible X watch-source curation",
    "claim": "With explicit user approval, Arcwell imported reviewed X watch manual rules into the real home and pause-only curation paused exactly the reviewed exclude handles while preserving all keep handles and all watch-source rows.",
    "non_claims": summary["non_claims"],
    "artifacts": {},
    "artifact_sha256": {},
    "adversarial_review_judgment": "promote for real-home pause-only apply proof; hold operational curation until worker/source-health pressure, scheduled enrichment, ops controls, and MCP/slash parity are proven.",
    "remaining_risks": [
        {
            "risk": "Worker/source-health pressure has not been measured after the real-home pause.",
            "next_action": "Run X monitor/source-health proof after curation."
        },
        {
            "risk": "No scheduler or ops UI review control proof exists for future curation cycles.",
            "next_action": "Add scheduled enrichment and ops controls before calling curation operational."
        }
    ]
}
for path in sorted(artifacts.iterdir()):
    if path.is_file() and path.name != "proof-packet.json":
        packet["artifacts"][path.stem.replace("-", "_")] = str(path)
        packet["artifact_sha256"][path.name] = hashlib.sha256(path.read_bytes()).hexdigest()
(artifacts / "proof-packet.json").write_text(json.dumps(packet, indent=2, sort_keys=True) + "\n")
packet["artifact_sha256"]["proof-packet.json"] = hashlib.sha256((artifacts / "proof-packet.json").read_bytes()).hexdigest()
(artifacts / "proof-packet.json").write_text(json.dumps(packet, indent=2, sort_keys=True) + "\n")
PY

log "verifying clean proof packet"
"$ARCWELL_BIN" proof verify-packet "$ARTIFACT_DIR/proof-packet.json" \
  >"$ARTIFACT_DIR/proof-packet-self-verification.json"
python3 - "$ARTIFACT_DIR/proof-packet-self-verification.json" <<'PY'
import json, sys
report = json.load(open(sys.argv[1]))
if not report.get("ok"):
    raise SystemExit(json.dumps(report, indent=2))
PY

log "recording durable proof packet"
python3 - "$PROOF_ROOT" "$ARTIFACT_DIR" >"$ARTIFACT_DIR/proof-ledger-record.json" <<'PY'
import hashlib, json, pathlib, subprocess, sys
root = pathlib.Path(sys.argv[1])
artifacts = pathlib.Path(sys.argv[2])
summary = json.loads((artifacts / "real-home-pause-summary.json").read_text())
validation = json.loads((artifacts / "real-home-pause-validation.json").read_text())
artifact_rows = []
for path in sorted(artifacts.iterdir()):
    if path.is_file() and path.name != "proof-ledger-record.json":
        artifact_rows.append({
            "artifact_kind": "local_file",
            "label": path.name,
            "path": str(path),
            "sha256": hashlib.sha256(path.read_bytes()).hexdigest(),
            "metadata": {"proof_root": str(root), "local_path_only": True}
        })
claims = [{
    "claim_key": "x-watch-curation-real-home-pause-only",
    "claim": "With explicit user approval, reviewed X watch manual rules were imported into the real Arcwell home and pause-only curation paused exactly the reviewed exclude handles while preserving keep handles and watch-source rows.",
    "status": "proven",
    "proof_level": "real_home_pause_only_proof",
    "evidence": [{
        "proof_root": str(root),
        "summary": str(artifacts / "real-home-pause-summary.json"),
        "validation": str(artifacts / "real-home-pause-validation.json"),
        "self_verification": str(artifacts / "proof-packet-self-verification.json")
    }],
    "refutation": [],
    "gates": validation["checks"]
}]
checks = [
    {"check_kind": "build", "command": "cargo build -p arcwell", "status": "passed", "exit_code": 0, "output_excerpt": "build completed", "metadata": {"artifact": str(artifacts / "cargo-build.log")}},
    {"check_kind": "severe_test", "command": "cargo test -p arcwell-core x_watch_curation -- --nocapture", "status": "passed", "exit_code": 0, "output_excerpt": "x_watch_curation tests passed", "metadata": {"artifact": str(artifacts / "x-watch-curation-tests.log")}},
    {"check_kind": "severe_test", "command": "cargo test -p arcwell-core x_watch_manual_rule -- --nocapture", "status": "passed", "exit_code": 0, "output_excerpt": "x_watch_manual_rule tests passed", "metadata": {"artifact": str(artifacts / "x-watch-manual-rule-tests.log")}},
    {"check_kind": "severe_test", "command": "cargo test -p arcwell-core proof -- --nocapture", "status": "passed", "exit_code": 0, "output_excerpt": "proof tests passed", "metadata": {"artifact": str(artifacts / "proof-tests.log")}},
    {"check_kind": "format", "command": "cargo fmt -- --check", "status": "passed", "exit_code": 0, "output_excerpt": "format check passed", "metadata": {"artifact": str(artifacts / "cargo-fmt-check.log")}},
    {"check_kind": "state_invariant", "command": "real-home pause-only validation", "status": "passed", "exit_code": 0, "output_excerpt": "exact reviewed excludes paused; manual keeps active; watch rows preserved", "metadata": {"artifact": str(artifacts / "real-home-pause-validation.json")}},
    {"check_kind": "verification", "command": "arcwell proof verify-packet proof-packet.json", "status": "passed", "exit_code": 0, "output_excerpt": "clean real-home proof packet verified ok", "metadata": {"artifact": str(artifacts / "proof-packet-self-verification.json")}}
]
cmd = [
    "target/debug/arcwell", "proof", "record",
    "--scope", "autonomous-knowledge-system",
    "--title", "X watch curation real-home pause-only proof",
    "--proof-level", "real_home_pause_only_proof",
    "--status", "passed",
    "--summary", "Real-home proof that approved reviewed X watch manual rules paused exactly the reviewed excludes while preserving keep handles and watch-source rows.",
    "--artifact-root", str(root),
    "--claims-json", json.dumps(claims),
    "--artifacts-json", json.dumps(artifact_rows),
    "--checks-json", json.dumps(checks),
    "--metadata-json", json.dumps({"capability": "x-watch-curation-real-home-pause-proof", "non_claims": summary["non_claims"]})
]
result = subprocess.run(cmd, cwd="/Users/chabotc/Projects/arcwell", text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
if result.returncode != 0:
    raise SystemExit(result.stderr)
print(result.stdout)
PY

log "proof root: $PROOF_ROOT"
