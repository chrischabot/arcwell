      "learned image compression survey neural codecs benchmark",
      "arXiv image compression survey neural learned compression benchmark",
      "official JPEG XL specification codec documentation compression",
      "AOM AVIF official documentation image compression codec",
      "Cloudinary image format benchmark AVIF WebP JPEG XL",
      "browser support AVIF WebP JPEG XL image compression 2026",
      "lossless image compression benchmark PNG WebP JPEG XL FLIF",
      "perceptual metrics image compression SSIM MS-SSIM VMAF Butteraugli",
    ],
  },
  "london-ai": {
    topic:
      "AI startup scene in London: companies, funding, talent, infrastructure, accelerators, and risks",
    minCandidates: 80,
    minSourceCards: 60,
    minFullSourceCards: 24,
    queries: [
      "London AI startups funding 2026 venture capital ecosystem",
      "London artificial intelligence startups official company announcements funding",
