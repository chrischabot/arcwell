#!/usr/bin/env node
/*
 * Run an end-to-end deep-research production proof in a disposable Arcwell home.
 *
 * This script intentionally drives the public CLI instead of private test APIs:
 * provider search -> host-search proof -> source cards -> run linkage ->
 * audit/report -> convergence -> close-loop -> proof packet.
 */

const fs = require("fs");
const os = require("os");
const path = require("path");
const { spawnSync } = require("child_process");

const root = path.resolve(__dirname, "..");

