#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ARCWELL_BIN="${ARCWELL_BIN:-$REPO_ROOT/target/debug/arcwell}"
if [ ! -x "$ARCWELL_BIN" ]; then
  ARCWELL_BIN="$(command -v arcwell || true)"
fi

if [ -z "${ARCWELL_BIN:-}" ] || [ ! -x "$ARCWELL_BIN" ]; then
  echo "BLOCKED: arcwell binary not found. Run: cargo build -p arcwell" >&2
  exit 2
fi

if ! command -v node >/dev/null 2>&1; then
  echo "BLOCKED: node is required for JSON assertions." >&2
  exit 2
fi

RUN_ID="telegram-live-smoke-$(date +%Y%m%dT%H%M%S)-$$"
export ARCWELL_HOME="${ARCWELL_SMOKE_HOME:-$REPO_ROOT/.arcwell/smoke/telegram-live-home}"
mkdir -p "$ARCWELL_HOME"
ARTIFACT_DIR="${ARCWELL_SMOKE_ARTIFACT_DIR:-$ARCWELL_HOME/artifacts/$RUN_ID}"
mkdir -p "$ARTIFACT_DIR"
tmp="$ARTIFACT_DIR"

CHAT_ID="${TELEGRAM_TEST_CHAT_ID:-${TELEGRAM_OWNER_CHAT_ID:-123456789}}"
LOCAL_CHAT_ID="${TELEGRAM_LOCAL_SMOKE_CHAT_ID:-local-$RUN_ID}"
OUTGOING_TEXT="Arcwell Telegram outgoing smoke $RUN_ID"
INCOMING_TEXT="${TELEGRAM_SMOKE_EXPECT_TEXT:-Arcwell Telegram incoming smoke $RUN_ID}"
WAIT_SECONDS="${TELEGRAM_SMOKE_WAIT_SECONDS:-90}"

redact() {
  sed -E \
    -e 's#/bot[0-9]+:[A-Za-z0-9_-]+#/bot[REDACTED]#g' \
    -e 's/[A-Za-z0-9_.=-]{40,}/[REDACTED]/g'
}

write_ops_snapshot() {
  local out="$1"
  printf '%s\n' '{"jsonrpc":"2.0","id":1,"method":"resources/read","params":{"uri":"arcwell://ops"}}' |
    "$ARCWELL_BIN" mcp >"$tmp/mcp-ops.jsonl"
  node - "$tmp/mcp-ops.jsonl" "$out" <<'NODE'
const fs = require("fs");
const [input, output] = process.argv.slice(2);
const lines = fs.readFileSync(input, "utf8").trim().split(/\r?\n/).filter(Boolean);
const response = JSON.parse(lines.at(-1));
if (response.error) {
  console.error(`FAIL: ops MCP resource read failed: ${JSON.stringify(response.error)}`);
  process.exit(1);
}
const text = response.result?.contents?.[0]?.text;
if (!text) {
  console.error(`FAIL: ops MCP resource response missing text: ${JSON.stringify(response)}`);
  process.exit(1);
}
fs.writeFileSync(output, text);
NODE
}

write_incoming_diagnostic() {
  local ops_path="$1"
  local diag_path="$2"
  node - "$ops_path" "$INCOMING_TEXT" "$diag_path" <<'NODE'
const fs = require("fs");
const [opsPath, needle, diagPath] = process.argv.slice(2);
const doc = JSON.parse(fs.readFileSync(opsPath, "utf8"));
const incoming = (doc.channel_messages || [])
  .filter((message) => message.channel === "telegram" && message.direction === "incoming");
const exact = incoming.filter((message) => message.body === needle);
const mismatches = incoming
  .filter((message) => message.body !== needle)
  .slice(0, 8)
  .map((message) => ({
    id: message.id,
    sender: message.sender,
    source_event_id: message.source_event_id,
    status: message.status,
    created_at: message.created_at,
    body_preview: String(message.body || "").slice(0, 160)
  }));
const diagnostic = {
  expected_text: needle,
  telegram_incoming_count: incoming.length,
  exact_match_count: exact.length,
  exact_matches: exact.map((message) => ({
    id: message.id,
    sender: message.sender,
    source_event_id: message.source_event_id,
    status: message.status,
    created_at: message.created_at
  })),
  recent_mismatches: mismatches
};
fs.writeFileSync(diagPath, `${JSON.stringify(diagnostic, null, 2)}\n`);
if (exact.length === 1) process.exit(0);
if (exact.length > 1) process.exit(3);
process.exit(1);
NODE
}

echo "Arcwell home: $ARCWELL_HOME"
echo "Smoke artifacts: $ARTIFACT_DIR"
echo "Running local send-authorization smoke against isolated chat id: $LOCAL_CHAT_ID"

if "$ARCWELL_BIN" telegram send "$LOCAL_CHAT_ID" "unauthorized local smoke" \
  --bot-token "fake-token" \
  --api-base "http://127.0.0.1:9" >"$tmp/unauthorized-send.json" 2>"$tmp/unauthorized-send.err"; then
  echo "FAIL: unauthorized Telegram send unexpectedly succeeded." >&2
  exit 1
fi
if ! grep -q "not authorized to send" "$tmp/unauthorized-send.err"; then
  echo "FAIL: unauthorized send failed for the wrong reason:" >&2
  redact <"$tmp/unauthorized-send.err" >&2
  exit 1
fi

"$ARCWELL_BIN" telegram authorize "telegram:chat:$LOCAL_CHAT_ID" \
  --read-projects \
  --write-projects >"$tmp/read-write-auth.json"
if "$ARCWELL_BIN" telegram send "$LOCAL_CHAT_ID" "read/write is not send" \
  --bot-token "fake-token" \
  --api-base "http://127.0.0.1:9" >"$tmp/read-write-send.json" 2>"$tmp/read-write-send.err"; then
  echo "FAIL: read/write-only Telegram chat was allowed to send." >&2
  exit 1
fi
if ! grep -q "not authorized to send" "$tmp/read-write-send.err"; then
  echo "FAIL: read/write-only send failed for the wrong reason:" >&2
  redact <"$tmp/read-write-send.err" >&2
  exit 1
fi

echo "Local authorization smoke passed."

missing=()
for name in TELEGRAM_BOT_TOKEN TELEGRAM_WEBHOOK_SECRET ARCWELL_EDGE_SECRET ARCWELL_EDGE_URL; do
  if [ -z "${!name:-}" ]; then
    missing+=("$name")
  fi
done
if [ -z "${TELEGRAM_TEST_CHAT_ID:-${TELEGRAM_OWNER_CHAT_ID:-}}" ]; then
  missing+=("TELEGRAM_TEST_CHAT_ID or TELEGRAM_OWNER_CHAT_ID")
fi

if [ "${ARCWELL_TELEGRAM_LIVE_CONFIRM:-}" != "disposable" ]; then
  missing+=("ARCWELL_TELEGRAM_LIVE_CONFIRM=disposable")
fi

if [ "${#missing[@]}" -gt 0 ]; then
  echo "BLOCKED: live Telegram/edge smoke not run; missing ${missing[*]}."
  echo "Local auth smoke passed. Re-run with a disposable bot/chat and required env vars for live proof."
  exit 2
fi

if [ -n "${TELEGRAM_WEBHOOK_URL:-}" ] && [ -z "${ARCWELL_TELEGRAM_WEBHOOK_URL:-}" ]; then
  echo "WARN: ignoring TELEGRAM_WEBHOOK_URL for Arcwell live smoke; use ARCWELL_TELEGRAM_WEBHOOK_URL to override intentionally." >&2
fi
WEBHOOK_URL="${ARCWELL_TELEGRAM_WEBHOOK_URL:-${ARCWELL_EDGE_URL%/}/telegram/webhook}"

echo "Checking Telegram bot token with getMe."
node - "$tmp/get-me.json" <<'NODE'
const fs = require("fs");
const https = require("https");
const out = process.argv[2];
const token = process.env.TELEGRAM_BOT_TOKEN;
https.get({
  hostname: "api.telegram.org",
  path: `/bot${token}/getMe`,
  method: "GET"
}, (response) => {
  let body = "";
  response.on("data", (chunk) => { body += chunk; });
  response.on("end", () => {
    fs.writeFileSync(out, body);
    const doc = JSON.parse(body);
    if (!doc.ok) {
      console.error("FAIL: Telegram getMe did not return ok=true.");
      process.exit(1);
    }
  });
}).on("error", (error) => {
  console.error(`FAIL: Telegram getMe request failed: ${error.message}`);
  process.exit(1);
});
NODE

echo "Installing Telegram webhook: $WEBHOOK_URL"
WEBHOOK_URL="$WEBHOOK_URL" node - "$tmp/set-webhook.json" <<'NODE'
const fs = require("fs");
const https = require("https");
const out = process.argv[2];
const token = process.env.TELEGRAM_BOT_TOKEN;
const body = new URLSearchParams({
  url: process.env.WEBHOOK_URL,
  secret_token: process.env.TELEGRAM_WEBHOOK_SECRET,
  drop_pending_updates: "true"
}).toString();
const request = https.request({
  hostname: "api.telegram.org",
  path: `/bot${token}/setWebhook`,
  method: "POST",
  headers: {
    "content-type": "application/x-www-form-urlencoded",
    "content-length": Buffer.byteLength(body)
  }
}, (response) => {
  let responseBody = "";
  response.on("data", (chunk) => { responseBody += chunk; });
  response.on("end", () => {
    fs.writeFileSync(out, responseBody);
    const doc = JSON.parse(responseBody);
    if (!doc.ok) {
      console.error(`FAIL: setWebhook failed: ${JSON.stringify(doc)}`);
      process.exit(1);
    }
  });
});
request.on("error", (error) => {
  console.error(`FAIL: setWebhook request failed: ${error.message}`);
  process.exit(1);
});
request.write(body);
request.end();
NODE

"$ARCWELL_BIN" telegram authorize "telegram:chat:$CHAT_ID" \
  --read-projects \
  --write-projects \
  --send >"$tmp/live-auth.json"

echo "Sending outgoing Telegram smoke message."
"$ARCWELL_BIN" telegram send "$CHAT_ID" "$OUTGOING_TEXT" \
  --bot-token "$TELEGRAM_BOT_TOKEN" >"$tmp/live-send.json"
node - "$tmp/live-send.json" <<'NODE'
const fs = require("fs");
const doc = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
if (!doc.ok || doc.message?.status !== "sent" || doc.delivery?.ok !== true) {
  console.error(`FAIL: outgoing Telegram send was not recorded as sent: ${JSON.stringify(doc)}`);
  process.exit(1);
}
NODE

echo "Send this exact message to the disposable Telegram chat now:"
echo "$INCOMING_TEXT"
echo "Re-run prompt if this times out:"
printf 'TELEGRAM_SMOKE_EXPECT_TEXT=%q ARCWELL_SMOKE_HOME=%q ARCWELL_TELEGRAM_LIVE_CONFIRM=disposable scripts/telegram-live-smoke\n' "$INCOMING_TEXT" "$ARCWELL_HOME"
echo "Waiting up to ${WAIT_SECONDS}s for webhook -> edge -> local drain -> channel record."

if [ "${ARCWELL_TELEGRAM_SYNTHETIC_INCOMING:-}" = "1" ]; then
  echo "Injecting a signed synthetic Telegram-shaped update through the deployed Arcwell webhook."
  TELEGRAM_CHAT_ID="$CHAT_ID" TELEGRAM_SMOKE_EXPECT_TEXT="$INCOMING_TEXT" node - "$tmp/synthetic-incoming.json" <<'NODE'
const fs = require("fs");
const https = require("https");

const out = process.argv[2];
const chatIdRaw = process.env.TELEGRAM_CHAT_ID;
const chatId = /^-?\d+$/.test(chatIdRaw) ? Number(chatIdRaw) : chatIdRaw;
const updateId = Math.floor(Date.now() / 1000);
const body = JSON.stringify({
  update_id: updateId,
  message: {
    message_id: updateId,
    date: Math.floor(Date.now() / 1000),
    chat: { id: chatId, type: "private" },
    from: { id: chatId, is_bot: false, username: "arcwell_smoke" },
    text: process.env.TELEGRAM_SMOKE_EXPECT_TEXT
  }
});
const url = new URL(`${process.env.ARCWELL_EDGE_URL.replace(/\/$/, "")}/telegram/webhook`);
const request = https.request({
  hostname: url.hostname,
  path: `${url.pathname}${url.search}`,
  method: "POST",
  headers: {
    "content-type": "application/json",
    "content-length": Buffer.byteLength(body),
    "x-telegram-bot-api-secret-token": process.env.TELEGRAM_WEBHOOK_SECRET
  }
}, (response) => {
  let responseBody = "";
  response.on("data", (chunk) => { responseBody += chunk; });
  response.on("end", () => {
    fs.writeFileSync(out, responseBody);
    if (response.statusCode < 200 || response.statusCode >= 300) {
      console.error(`FAIL: synthetic Telegram webhook injection returned HTTP ${response.statusCode}.`);
      process.exit(1);
    }
    const doc = JSON.parse(responseBody);
    if (!doc.accepted && !doc.duplicate) {
      console.error(`FAIL: synthetic Telegram webhook injection was not accepted: ${JSON.stringify(doc)}`);
      process.exit(1);
    }
  });
});
request.on("error", (error) => {
  console.error(`FAIL: synthetic Telegram webhook injection failed: ${error.message}`);
  process.exit(1);
});
request.write(body);
request.end();
NODE
fi

deadline=$((SECONDS + WAIT_SECONDS))
found=0
duplicate=0
while [ "$SECONDS" -lt "$deadline" ]; do
  "$ARCWELL_BIN" edge drain-remote \
    --url "$ARCWELL_EDGE_URL" \
    --secret "$ARCWELL_EDGE_SECRET" \
    --max-events 10 >"$tmp/edge-drain.json" || true
  "$ARCWELL_BIN" telegram drain --max-events 10 >"$tmp/telegram-drain.json" || true
  write_ops_snapshot "$tmp/ops.json"
  set +e
  write_incoming_diagnostic "$tmp/ops.json" "$tmp/incoming-diagnostic.json"
  diagnostic_status=$?
  set -e
  if [ "$diagnostic_status" -eq 0 ]; then
    found=1
    break
  elif [ "$diagnostic_status" -eq 3 ]; then
    duplicate=1
    break
  fi
  sleep 3
done

if [ "$duplicate" -eq 1 ]; then
  echo "FAIL: incoming Telegram phrase was recorded more than once; duplicate diagnostics: $tmp/incoming-diagnostic.json"
  exit 1
fi

if [ "$found" -ne 1 ]; then
  echo "BLOCKED: incoming Telegram webhook was not observed exactly once before timeout."
  echo "Checked edge drain and local telegram drain repeatedly."
  echo "Diagnostics: $tmp/incoming-diagnostic.json"
  echo "Preserved Arcwell home: $ARCWELL_HOME"
  echo "If the chat message differed, send the exact phrase printed above and re-run the command shown above."
  exit 2
fi

"$ARCWELL_BIN" edge drain-remote \
  --url "$ARCWELL_EDGE_URL" \
  --secret "$ARCWELL_EDGE_SECRET" \
  --max-events 10 >"$tmp/edge-drain-after.json" || true
"$ARCWELL_BIN" telegram drain --max-events 10 >"$tmp/telegram-drain-after.json" || true
write_ops_snapshot "$tmp/ops-after.json"
set +e
write_incoming_diagnostic "$tmp/ops-after.json" "$tmp/incoming-diagnostic-after.json"
diagnostic_status=$?
set -e
if [ "$diagnostic_status" -ne 0 ]; then
  echo "FAIL: expected exactly one incoming channel record after second drain; diagnostics: $tmp/incoming-diagnostic-after.json" >&2
  exit 1
fi

echo "PASS: Telegram webhook drained exactly once and outgoing delivery was recorded."
echo "Artifacts preserved at: $ARTIFACT_DIR"
