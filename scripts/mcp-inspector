#!/usr/bin/env bash
set -euo pipefail

# Launch or preflight the official MCP Inspector against arcwell mcp.

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ARCWELL_BIN="${ARCWELL_BIN:-$REPO_ROOT/target/debug/arcwell}"
ARCWELL_HOME_VALUE="${ARCWELL_HOME:-}"
CHECK_ONLY=0
NO_BUILD=0

usage() {
  cat <<'USAGE'
Usage: scripts/mcp-inspector [--check-only] [--no-build] [--bin path] [--arcwell-home path]

Runs the official @modelcontextprotocol/inspector package against `arcwell mcp`.
The Inspector is interactive; use scripts/claude-mcp-smoke for automated stdio
regression coverage.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --check-only) CHECK_ONLY=1 ;;
    --no-build) NO_BUILD=1 ;;
    --bin) ARCWELL_BIN="${2:-}"; shift ;;
    --arcwell-home) ARCWELL_HOME_VALUE="${2:-}"; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "unknown argument: $1" >&2; usage >&2; exit 2 ;;
  esac
  shift
done

command -v npx >/dev/null 2>&1 || {
  echo "BLOCKED: npx is not available, so @modelcontextprotocol/inspector cannot be launched." >&2
  exit 2
}

if [[ "$CHECK_ONLY" == "1" ]]; then
  npm view @modelcontextprotocol/inspector version >/dev/null
  echo "PASS: @modelcontextprotocol/inspector is reachable through npm."
  exit 0
fi

if [[ "$NO_BUILD" == "0" && "$ARCWELL_BIN" == "$REPO_ROOT/target/debug/arcwell" ]]; then
  (cd "$REPO_ROOT" && cargo build -p arcwell)
fi

[[ -x "$ARCWELL_BIN" ]] || {
  echo "FAIL: arcwell binary is missing or not executable: $ARCWELL_BIN" >&2
  exit 1
}

if [[ -z "$ARCWELL_HOME_VALUE" ]]; then
  ARCWELL_HOME_VALUE="$(mktemp -d "${TMPDIR:-/tmp}/arcwell-mcp-inspector.XXXXXX")"
fi

echo "Launching MCP Inspector with ARCWELL_HOME=$ARCWELL_HOME_VALUE"
ARCWELL_HOME="$ARCWELL_HOME_VALUE" npx -y @modelcontextprotocol/inspector "$ARCWELL_BIN" mcp
